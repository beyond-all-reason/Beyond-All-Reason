		<!-- LP: LIGHT TYPE + PLACEMENT MODE + DISTRIBUTION (outside collapsibles, always at top) -->
		<div id="tf-lp-submodes">
			<div id="btn-toggle-lt-type" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
				<img id="img-toggle-lt-type" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
				<div class="tf-collapsible-title">LIGHT TYPE</div>
				<div id="lights-type-notify-dot" class="tf-notify-dot hidden"></div>
			</div>
			<div id="section-lt-type">
			<div class="flex flex-row gap-1 mb-1">
				<div id="btn-lt-point" class="tf-mode-btn tf-lt-btn active" onclick="widget:lpSetType('point'); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/lt_point.png" />
					<div class="tf-btn-text">Point</div>
				</div>
				<div id="btn-lt-cone" class="tf-mode-btn tf-lt-btn" onclick="widget:lpSetType('cone'); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/lt_cone.png" />
					<div class="tf-btn-text">Cone</div>
				</div>
				<div id="btn-lt-beam" class="tf-mode-btn tf-lt-btn" onclick="widget:lpSetType('beam'); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/lt_beam.png" />
					<div class="tf-btn-text">Beam</div>
				</div>
			</div>
			</div><!-- /section-lt-type -->

			<div id="btn-toggle-lt-placement" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
				<img id="img-toggle-lt-placement" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
				<div class="tf-collapsible-title">PLACEMENT MODE</div>
			</div>
			<div id="section-lt-placement">
			<div class="flex flex-row gap-1 mb-1">
				<div id="btn-lp-point" class="tf-mode-btn tf-lp-mode-btn" onclick="widget:lpSetMode('point'); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/fp_point.png" />
					<div class="tf-btn-text">Single</div>
				</div>
				<div id="btn-lp-scatter" class="tf-mode-btn tf-lp-mode-btn" onclick="widget:lpSetMode('scatter'); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/fp_scatter.png" />
					<div class="tf-btn-text">Scatter</div>
				</div>
				<div id="btn-lp-remove" class="tf-mode-btn tf-lp-mode-btn" onclick="widget:lpSetMode('remove'); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/fp_remove.png" />
					<div class="tf-btn-text">Remove</div>
				</div>
			</div>
			</div><!-- /section-lt-placement -->

			<!-- DISTRIBUTION nested under PLACEMENT MODE -->
			<div id="btn-toggle-lt-dist" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
				<img id="img-toggle-lt-dist" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
				<div class="tf-collapsible-title">DISTRIBUTION</div>
			</div>
			<div id="section-lt-dist">
			<div class="flex flex-row gap-1 mb-1">
				<div id="btn-lp-dist-random" class="tf-fp-dist-btn active" onclick="widget:lpSetDist('random'); event:StopPropagation()">
					<img class="tf-icon-dist" src="/luaui/images/terraform_brush/fp_scatter.png" />
					<div class="tf-btn-text">Random</div>
				</div>
				<div id="btn-lp-dist-regular" class="tf-fp-dist-btn" onclick="widget:lpSetDist('regular'); event:StopPropagation()">
					<img class="tf-icon-dist" src="/luaui/images/terraform_brush/dist_regular.png" />
					<div class="tf-btn-text">Regular</div>
				</div>
				<div id="btn-lp-dist-clustered" class="tf-fp-dist-btn" onclick="widget:lpSetDist('clustered'); event:StopPropagation()">
					<img class="tf-icon-dist" src="/luaui/images/terraform_brush/dist_clustered.png" />
					<div class="tf-btn-text">Clustered</div>
				</div>
			</div>
			</div><!-- /section-lt-dist -->
			<div class="divider-horizontal-dark"></div>
		</div><!-- /tf-lp-submodes -->

		<!-- LP: DISPLAY -->
		<div id="btn-toggle-lp-overlays" class="flex flex-row items-center gap-1 mb-1" style="cursor: pointer;">
			<img id="img-toggle-lp-overlays" class="tf-icon-sm" src="/luaui/images/terraform_brush/plus.png" />
