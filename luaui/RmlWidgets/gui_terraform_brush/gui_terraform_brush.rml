						<div id="gb-btn-manual-spoke-down" onclick="widget:gbManualSpokeDown(); event:StopPropagation()" class="tf-sm-btn">
							<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
						</div>
						<input type="range" id="gb-slider-manual-spoke" onchange="widget:gbOnManualSpokeChange(element); event:StopPropagation()" class="tf-slider" min="0" max="23" step="1" value="0" />
						<div id="gb-btn-manual-spoke-up" onclick="widget:gbManualSpokeUp(); event:StopPropagation()" class="tf-sm-btn">
							<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
						</div>
					</div>
				</div>
