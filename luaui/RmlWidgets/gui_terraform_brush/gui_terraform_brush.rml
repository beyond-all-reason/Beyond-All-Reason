					<div id="gb-btn-angle-autosnap" onclick="widget:gbAngleAutoSnap(); event:StopPropagation()" class="tf-inline-chip" style="margin-left: 4dp;">Auto-Snap</div>
				</div>
				<div id="gb-angle-manual-spoke-row" class="hidden mb-1">
