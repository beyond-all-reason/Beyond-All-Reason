					<div id="gb-btn-measure-ruler" onclick="widget:gbMeasureRuler(); event:StopPropagation()" class="tf-overlay-chip" style="flex: 1; text-align: center;">
						<div class="tf-overlay-chip-label" style="text-align: center;">Ruler Mode</div>
					</div>
					<div id="gb-btn-measure-sticky" onclick="widget:gbMeasureSticky(); event:StopPropagation()" class="tf-overlay-chip" style="flex: 1; text-align: center;">
						<div class="tf-overlay-chip-label" style="text-align: center;">Sticky</div>
