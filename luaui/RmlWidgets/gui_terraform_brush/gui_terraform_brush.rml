<rml>
<head>
	<link type="text/rcss" href="../styles.rcss" />
	<link type="text/rcss" href="../rml-utility-classes.rcss" />
	<link type="text/rcss" href="../palette-standard-global.rcss" />
	<link type="text/rcss" href="../themes/theme-base.rcss" />
	<link type="text/rcss" href="gui_terraform_brush.rcss" />
</head>
<body data-model="terraform_brush_model">
	<div id="tf-root" class="tf-root hidden widget-shadow rounded-md bg-darkest p-2-5">
		<div class="flex flex-row justify-between items-center mb-2">
			<div id="tf-handle" class="tf-drag-handle text-2xl font-bold text-light text-outline-darker" style="flex: 1;">Terraform Brush</div>
			<div id="btn-sound" class="tf-header-btn tf-sound-btn" onclick="widget:guideToggleSound(element); event:StopPropagation()"><img class="tf-header-icon" src="/luaui/images/terraform_brush/volume.png" /></div>
			<div id="btn-guide" class="tf-header-btn tf-guide-btn" onclick="widget:guideToggle(element); event:StopPropagation()"><span>?</span></div>
			<div id="btn-passthrough" class="tf-header-btn tf-passthrough-btn" onclick="widget:guideTogglePassthrough(); event:StopPropagation()">
				<img id="passthrough-icon-pause" class="tf-header-icon" src="/luaui/images/terraform_brush/passthrough_pause.png" data-if="!passthroughActive" />
				<img id="passthrough-icon-play" class="tf-header-icon" src="/luaui/images/terraform_brush/passthrough_play.png" data-if="passthroughActive" />
			</div>
			<div id="btn-settings" class="tf-header-btn tf-settings-btn" onclick="widget:guideToggleSettings(); event:StopPropagation()"><img class="tf-header-icon" src="/luaui/images/terraform_brush/settings.png" /></div>
			<div id="btn-quit" class="tf-header-btn tf-quit-btn"><img class="tf-header-icon" src="/luaui/images/terraform_brush/close.png" /></div>
		</div>
		<div id="status-summary" class="tf-status-summary mb-1"></div>
		<div id="btn-toggle-terrain" class="flex flex-row items-center mt-2 mb-0-5" style="cursor: pointer;">
			<img id="img-toggle-terrain" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
			<div class="tf-collapsible-title">TERRAIN</div>
		</div>
		<div id="section-terrain">
		<div id="tf-mapdamage-notice" class="tf-notice-banner hidden">Map deformation is disabled on this map. Enable it via the <span class="tf-notice-highlight">Disable Map Deformation</span> mod option before starting to use terrain editing tools.</div>
		<div class="flex flex-row gap-1 mb-1">
			<div id="btn-raise" class="tf-mode-btn tf-btn-raise" onclick="widget:tfSetMode('raise'); event:StopPropagation()">
				<div class="tf-keybind-badge">LMB</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_raise.png" />
				<div class="tf-btn-text">RAISE</div>
			</div>
			<div id="btn-lower" class="tf-mode-btn tf-btn-lower" onclick="widget:tfSetMode('lower'); event:StopPropagation()">
				<div class="tf-keybind-badge">RMB</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_lower.png" />
				<div class="tf-btn-text">LOWER</div>
			</div>
			<div id="btn-level" class="tf-mode-btn tf-btn-level" onclick="widget:tfSetMode('smooth'); event:StopPropagation()">
				<div class="tf-keybind-badge">L</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_level.png" />
				<div class="tf-btn-text">MODIFY</div>
			</div>
			<div id="btn-ramp" class="tf-mode-btn tf-btn-ramp" onclick="widget:tfSetMode('ramp'); event:StopPropagation()">
				<div class="tf-keybind-badge">R</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_ramp.png" />
				<div class="tf-btn-text">RAMP</div>
			</div>
			<div id="btn-restore" class="tf-mode-btn tf-btn-restore" onclick="widget:tfSetMode('restore'); event:StopPropagation()">
				<div class="tf-keybind-badge">E</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_restore.png" />
				<div class="tf-btn-text">RESTORE</div>
			</div>
			<div id="btn-noise" class="tf-mode-btn tf-btn-noise" onclick="widget:tfSetMode('noise'); event:StopPropagation()">
				<div class="tf-keybind-badge">N</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_noise.png" />
				<div class="tf-btn-text">NOISE</div>
			</div>
		</div>
		</div>
		<div class="divider-horizontal-dark"></div>
		<div id="btn-toggle-tools" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
			<img id="img-toggle-tools" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
			<div class="tf-collapsible-title">TOOLS</div>
		</div>
		<div id="section-tools">
		<div id="tf-tools-rows" class="flex flex-row gap-1 mb-1">
			<div id="btn-metal" class="tf-mode-btn tf-btn-metal" onclick="widget:tfSwitchMetal(); event:StopPropagation()">
				<div class="tf-keybind-badge">M</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_metal.png" />
				<div class="tf-btn-text">METAL</div>
			</div>
			<div id="btn-features" class="tf-mode-btn tf-btn-features" onclick="widget:tfSwitchFeatures(); event:StopPropagation()">
				<div class="tf-keybind-badge">F</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_features.png" />
				<div class="tf-btn-text">FEATURES</div>
			</div>
			<div id="btn-grass" class="tf-mode-btn tf-btn-grass" onclick="widget:tfSwitchGrass(); event:StopPropagation()">
				<div class="tf-keybind-badge">K</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_grass.png" />
				<div class="tf-btn-text">GRASS</div>
			</div>
			<div id="btn-splat" class="tf-mode-btn tf-btn-splat" onclick="widget:tfSwitchSplat(); event:StopPropagation()">
				<div class="tf-keybind-badge">P</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_splat.png" />
				<div class="tf-btn-text">SPLAT</div>
			</div>
			<div id="btn-decals" class="tf-mode-btn tf-btn-decals" onclick="widget:tfSwitchDecals(); event:StopPropagation()">
				<div class="tf-keybind-badge">G</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_decals.png" />
				<div class="tf-btn-text">DECALS</div>
			</div>
		</div>
		<div id="tf-tools-rows2" class="flex flex-row gap-1 mb-1">
			<div id="btn-weather" class="tf-mode-btn tf-btn-weather" onclick="widget:tfSwitchWeather(); event:StopPropagation()">
				<div class="tf-keybind-badge">W</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_weather.png" />
				<div class="tf-btn-text">WEATHER</div>
			</div>
			<div id="btn-lights" class="tf-mode-btn tf-btn-lights" onclick="widget:tfSwitchLights(); event:StopPropagation()">
				<div class="tf-keybind-badge">L</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_lights.png" />
				<div class="tf-btn-text">LIGHTS</div>
			</div>
			<div id="btn-startpos" class="tf-mode-btn tf-btn-startpos" onclick="widget:tfSwitchStartpos(); event:StopPropagation()">
				<div class="tf-keybind-badge">S</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_startpos.png" />
				<div class="tf-btn-text">STARTS</div>
			</div>
			<div id="btn-environment" class="tf-mode-btn tf-btn-environment" onclick="widget:tfSwitchEnv(); event:StopPropagation()">
				<div class="tf-keybind-badge">V</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_environment.png" />
				<div class="tf-btn-text">SCENE</div>
			</div>
			<div id="btn-clone" class="tf-mode-btn tf-btn-clone" onclick="widget:clOnClone(); event:StopPropagation()">
				<div class="tf-keybind-badge">J</div>
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/mode_clone.png" />
				<div class="tf-btn-text">CLONE</div>
			</div>
		</div>
		</div>

		<div class="divider-horizontal-dark"></div>

		<!-- Start Positions sub-mode row (visible only when StartPos tool active) -->
		<div id="tf-startpos-submodes" class="hidden">
			<div id="btn-toggle-sp-mode" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
				<img id="img-toggle-sp-mode" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
				<div class="tf-collapsible-title">START POSITIONS</div>
				<div id="startpos-mode-notify-dot" class="tf-notify-dot hidden"></div>
			</div>
			<div id="section-sp-mode">
			<div class="flex flex-row gap-1 mb-1">
				<div id="btn-sp-express" class="tf-mode-btn tf-sp-btn-express" onclick="widget:spSetSubMode('express'); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/fp_point.png" />
					<div class="tf-btn-text">Express</div>
				</div>
				<div id="btn-sp-shape" class="tf-mode-btn tf-sp-btn-shape" onclick="widget:spSetSubMode('startbox'); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/shape_hexagon.png" />
					<div class="tf-btn-text">Shape</div>
				</div>
			</div>
			<!-- Startbox placement-mode picker (only visible in startbox submode). Same styling as main submode row. -->
			<div id="sp-startbox-mode-row" class="flex flex-row gap-1 mb-1 hidden">
				<div id="btn-sp-sbx-box" class="tf-mode-btn tf-sp-btn-sbx-box" onclick="widget:spSetStartboxMode('box'); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/shape_square.png" />
					<div class="tf-btn-text">Box</div>
				</div>
				<div id="btn-sp-sbx-polygon" class="tf-mode-btn tf-sp-btn-sbx-polygon active" onclick="widget:spSetStartboxMode('polygon'); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/shape_hexagon.png" />
					<div class="tf-btn-text">Polygon</div>
				</div>
				<div id="btn-sp-sbx-freedraw" class="tf-mode-btn tf-sp-btn-sbx-freedraw" onclick="widget:spSetStartboxMode('freedraw'); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/freedraw.png" />
					<div class="tf-btn-text">Free</div>
				</div>
			</div>
			</div><!-- /section-sp-mode -->
			<div class="divider-horizontal-dark"></div>
		</div>

		<!-- Start Positions controls (visible only when StartPos tool active) -->
		<div id="tf-startpos-controls" class="hidden">
		<div class="divider-horizontal-dark"></div>

		<!-- ST: DISPLAY -->
		<div id="btn-toggle-st-overlays" class="flex flex-row items-center gap-1 mb-1" style="cursor: pointer;">
			<img id="img-toggle-st-overlays" class="tf-icon-sm" src="/luaui/images/terraform_brush/plus.png" />
			<div class="text-base text-keybind" style="margin-right: 2dp;">DISPLAY</div>
			<div id="warn-chip-st-overlays" class="tf-overlay-chip tf-overlay-chip-warn hidden"><div class="tf-overlay-chip-label">Active</div></div>
		</div>
		<div id="section-st-overlays" class="hidden">
		<div class="flex flex-row items-center gap-1 mb-1">
			<div id="btn-st-grid-overlay" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label">Grid</div>
			</div>
			<div id="btn-st-height-colormap" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label">Height Map</div>
			</div>
		</div>
		</div><!-- /section-st-overlays -->

		<div class="divider-horizontal-dark"></div>

		<!-- ST: INSTRUMENTS -->
		<div id="btn-toggle-st-instruments" class="flex flex-row items-center gap-1 mb-1" style="cursor: pointer;">
			<img id="img-toggle-st-instruments" class="tf-icon-sm" src="/luaui/images/terraform_brush/plus.png" />
			<div class="text-base text-keybind" style="margin-right: 2dp;">INSTRUMENTS</div>
			<div id="warn-chip-st-instruments" class="tf-overlay-chip tf-overlay-chip-warn hidden"><div class="tf-overlay-chip-label">Active</div></div>
		</div>
		<div id="section-st-instruments" class="hidden">
		<div class="flex flex-row items-center gap-1 mb-1">
			<div id="btn-st-grid-snap" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label" style="text-align: center;">Grid Snap</div>
			</div>
			<div id="btn-st-angle-snap" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label" style="text-align: center;">Protractor</div>
			</div>
			<div id="btn-st-measure" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label" style="text-align: center;">Measure</div>
			</div>
			<div id="btn-st-symmetry" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label" style="text-align: center;">Symmetry</div>
			</div>
		</div>
		<div id="st-measure-toolbar-row" class="tf-instrument-sub hidden mb-1">
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-st-measure-show-length" class="tf-overlay-chip" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Show Length</div>
				</div>
				<div id="btn-st-measure-clear" class="tf-sm-btn" style="flex: 1;">
					<div class="text-sm" style="text-align: center;">Clear All</div>
				</div>
			</div>
		</div>
		<div id="st-symmetry-toolbar-row" class="tf-instrument-sub hidden mb-1">
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-st-symmetry-radial" class="tf-overlay-chip" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Radial</div>
				</div>
				<div id="btn-st-symmetry-mirror-x" class="tf-overlay-chip" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Mirror X</div>
				</div>
				<div id="btn-st-symmetry-mirror-y" class="tf-overlay-chip" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Mirror Y</div>
				</div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-st-symmetry-place-origin" class="tf-sm-btn" style="flex: 1;">
					<div class="text-sm" style="text-align: center;">Set Origin</div>
				</div>
				<div id="btn-st-symmetry-center-origin" class="tf-sm-btn" style="flex: 1;">
					<div class="text-sm" style="text-align: center;">Center</div>
				</div>
			</div>
		</div>
		</div><!-- /section-st-instruments -->

		<div class="divider-horizontal-dark"></div>

		<!-- ST: CONTROLS -->
		<div id="btn-toggle-st-controls" class="flex flex-row items-center gap-1 mb-1" style="cursor: pointer;">
			<img id="img-toggle-st-controls" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
			<div class="text-base text-keybind" style="margin-right: 2dp;">CONTROLS</div>
		</div>
		<div id="section-st-controls">

			<!-- Ally Teams count -->
			<div class="flex flex-row items-center mb-1">
				<div class="text-lg text-light font-bold">Ally Teams</div>
				<div id="sp-allyteams-label" class="text-lg text-light">2</div>
				<div id="slider-sp-allyteams-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
				<div id="slider-sp-allyteams-transport" class="tf-transport-group hidden">
					<div id="slider-sp-allyteams-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
					<div id="slider-sp-allyteams-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
					<div id="slider-sp-allyteams-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
				</div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-sp-teams-down" class="tf-sm-btn" onclick="widget:spTeamsDown(); event:StopPropagation()"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" /></div>
				<input id="slider-sp-allyteams" type="range" class="tf-slider" min="2" max="32" step="1" value="2" style="flex:1;" onchange="widget:spOnAllyTeamsChange(element); event:StopPropagation()" />
				<div id="btn-sp-teams-up" class="tf-sm-btn" onclick="widget:spTeamsUp(); event:StopPropagation()"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" /></div>
				<input type="text" id="slider-sp-allyteams-numbox" class="tf-slider-numbox" value="2" />
			</div>

			<!-- Teams per Ally (for 2..16 players per allyteam; enables 32x16=512 capped at 256) -->
			<div class="flex flex-row items-center mb-1">
				<div class="text-lg text-light font-bold">Teams / Ally</div>
				<div id="sp-teams-per-ally-label" class="text-lg text-light">1</div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-sp-teams-per-ally-down" class="tf-sm-btn" onclick="widget:spTeamsPerAllyDown(); event:StopPropagation()"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" /></div>
				<input id="slider-sp-teams-per-ally" type="range" class="tf-slider" min="1" max="16" step="1" value="1" style="flex:1;" onchange="widget:spOnTeamsPerAllyChange(element); event:StopPropagation()" />
				<div id="btn-sp-teams-per-ally-up" class="tf-sm-btn" onclick="widget:spTeamsPerAllyUp(); event:StopPropagation()"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" /></div>
				<input type="text" id="slider-sp-teams-per-ally-numbox" class="tf-slider-numbox" value="1" />
			</div>

			<!-- Placement Mode Toggle -->
			<div class="flex flex-row gap-1 items-center mb-1">
				<div class="text-lg text-light font-bold" style="flex:1;">Placement</div>
				<div id="btn-sp-placement-mode" class="tf-sm-btn" style="padding: 2dp 10dp;" onclick="widget:spTogglePlacement(); event:StopPropagation()">ROUND-ROBIN</div>
			</div>

			<!-- Shape Count (for shape mode) -->
			<div id="sp-shape-options" class="hidden">
				<div class="flex flex-row items-center mb-1">
					<div class="text-lg text-light font-bold">Positions</div>
					<div id="sp-count-label" class="text-lg text-light">4</div>
					<div id="slider-sp-count-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
					<div id="slider-sp-count-transport" class="tf-transport-group hidden">
						<div id="slider-sp-count-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
						<div id="slider-sp-count-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
						<div id="slider-sp-count-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
					</div>
				</div>
				<div class="flex flex-row gap-1 items-center mb-1">
					<div id="btn-sp-count-down" class="tf-sm-btn" onclick="widget:spCountDown(); event:StopPropagation()"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" /></div>
					<input id="slider-sp-count" type="range" class="tf-slider" min="2" max="256" step="1" value="4" style="flex:1;" onchange="widget:spOnCountChange(element); event:StopPropagation()" />
					<div id="btn-sp-count-up" class="tf-sm-btn" onclick="widget:spCountUp(); event:StopPropagation()"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" /></div>
					<input type="text" id="slider-sp-count-numbox" class="tf-slider-numbox" value="4" />
				</div>

				<!-- Shape Size -->
				<div class="flex flex-row items-center mb-1">
					<div class="text-lg text-light font-bold">Size</div>
					<div id="sp-size-label" class="text-lg text-light">2000</div>
					<div id="sp-slider-size-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
					<div id="sp-slider-size-transport" class="tf-transport-group hidden">
						<div id="sp-slider-size-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
						<div id="sp-slider-size-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
						<div id="sp-slider-size-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
					</div>
				</div>
				<div class="flex flex-row gap-1 items-center mb-1">
					<div id="btn-sp-size-down" class="tf-sm-btn" onclick="widget:spSizeDown(); event:StopPropagation()"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" /></div>
					<input id="slider-sp-size" type="range" class="tf-slider" min="64" max="16384" step="32" value="2000" style="flex:1;" onchange="widget:spOnSizeChange(element); event:StopPropagation()" />
					<div id="btn-sp-size-up" class="tf-sm-btn" onclick="widget:spSizeUp(); event:StopPropagation()"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" /></div>
					<input type="text" id="slider-sp-size-numbox" class="tf-slider-numbox" value="2000" />
				</div>

				<!-- Shape Rotation -->
				<div class="flex flex-row items-center mb-1">
					<div class="text-lg text-light font-bold">Rotation</div>
					<div id="sp-rotation-label" class="text-lg text-light">0&#176;</div>
					<div id="sp-slider-rotation-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
					<div id="sp-slider-rotation-transport" class="tf-transport-group hidden">
						<div id="sp-slider-rotation-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
						<div id="sp-slider-rotation-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
						<div id="sp-slider-rotation-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
					</div>
				</div>
				<div class="flex flex-row gap-1 items-center mb-1">
					<div id="btn-sp-rot-ccw" class="tf-sm-btn" onclick="widget:spRotCCW(); event:StopPropagation()"><img class="tf-icon-sm" src="/luaui/images/terraform_brush/rot_ccw.png" /></div>
					<input id="slider-sp-rotation" type="range" class="tf-slider" min="0" max="359" step="1" value="0" style="flex:1;" onchange="widget:spOnRotationChange(element); event:StopPropagation()" />
					<div id="btn-sp-rot-cw" class="tf-sm-btn" onclick="widget:spRotCW(); event:StopPropagation()"><img class="tf-icon-sm" src="/luaui/images/terraform_brush/rot_cw.png" /></div>
					<input type="text" id="slider-sp-rotation-numbox" class="tf-slider-numbox" value="0" />
				</div>

				<!-- Random Positions button -->
				<div class="flex flex-row gap-1 mb-1">
					<div id="btn-sp-random" class="tf-action-btn" style="flex: 1;" onclick="widget:spRandom(); event:StopPropagation()">
						<div class="tf-action-btn-text">RANDOM POSITIONS</div>
					</div>
				</div>
			</div>

			<!-- Shape selector -->
			<div id="sp-shape-row" class="hidden">
				<div class="text-lg text-light font-bold mb-1">SHAPE</div>
				<div class="flex flex-row gap-1 mb-1">
					<div id="btn-sp-shape-circle" class="tf-mode-btn" onclick="widget:spSetShape('circle'); event:StopPropagation()">
						<img class="tf-icon-md" src="/luaui/images/terraform_brush/shape_circle.png" />
						<div class="tf-btn-text">Circle</div>
					</div>
					<div id="btn-sp-shape-square" class="tf-mode-btn" onclick="widget:spSetShape('square'); event:StopPropagation()">
						<img class="tf-icon-md" src="/luaui/images/terraform_brush/shape_square.png" />
						<div class="tf-btn-text">Square</div>
					</div>
					<div id="btn-sp-shape-hexagon" class="tf-mode-btn" onclick="widget:spSetShape('hexagon'); event:StopPropagation()">
						<img class="tf-icon-md" src="/luaui/images/terraform_brush/shape_hexagon.png" />
						<div class="tf-btn-text">Hex</div>
					</div>
					<div id="btn-sp-shape-triangle" class="tf-mode-btn" onclick="widget:spSetShape('triangle'); event:StopPropagation()">
						<img class="tf-icon-md" src="/luaui/images/terraform_brush/shape_triangle.png" />
						<div class="tf-btn-text">Tri</div>
					</div>
				</div>
				<div class="divider-horizontal-dark"></div>
			</div>

			<!-- Express mode hint -->
			<div id="sp-express-hint">
			</div>
			<!-- Startbox mode hint -->
			<div id="sp-startbox-hint" class="hidden">
				<div id="sp-sbx-hint-box" class="text-sm text-keybind mb-1 hidden">LMB drag: rectangle &amp;middot; RMB: remove last box &amp;middot; Drag vertices to reshape</div>
				<div id="sp-sbx-hint-polygon" class="text-sm text-keybind mb-1">LMB: add vertex &amp;middot; RMB: finish box &amp;middot; Drag vertices to move</div>
				<div id="sp-sbx-hint-freedraw" class="text-sm text-keybind mb-1 hidden">LMB drag: free-draw (smoothed) &amp;middot; RMB: cancel &amp;middot; Drag vertices to tweak</div>
			</div>

			<!-- Action buttons -->
			<div class="flex flex-row gap-1 mb-1">
				<div id="btn-sp-clear" class="tf-action-btn" style="flex: 1;" onclick="widget:spClear(); event:StopPropagation()">
					<div class="tf-action-btn-text">CLEAR ALL</div>
				</div>
			</div>

			<!-- Save/Load -->
			<div class="flex flex-row gap-1 mb-1">
				<div id="btn-sp-save" class="tf-action-btn tf-save-btn" style="flex: 1;" onclick="widget:spSave(); event:StopPropagation()">
					<div class="tf-action-btn-text">SAVE</div>
				</div>
				<div id="btn-sp-load" class="tf-action-btn" style="flex: 1;" onclick="widget:spLoad(); event:StopPropagation()">
					<div class="tf-action-btn-text">LOAD</div>
				</div>
			</div>

			<div class="divider-horizontal-dark"></div>
		</div><!-- /section-st-controls -->
