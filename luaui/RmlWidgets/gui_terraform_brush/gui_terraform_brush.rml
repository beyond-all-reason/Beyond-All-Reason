				</div>
				<input type="range" id="slider-mb-length" class="tf-slider" min="2" max="50" step="1" value="10" onchange="widget:mbOnLengthChange(element); event:StopPropagation()" />
				<div id="btn-mb-length-up" class="tf-sm-btn" onclick="widget:mbLengthUp(); event:StopPropagation()">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
				</div>
				<input type="text" id="slider-mb-length-numbox" class="tf-slider-numbox" value="0" />
			</div>

			<!-- Metal Fall-off Curve -->
			<div class="flex flex-row items-center mb-1">
				<div class="text-lg text-light">FALL-OFF: <span class="text-xl font-bold tf-slider-val" id="mb-curve-label">1.0</span></div>
				<div id="slider-mb-curve-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
				<div id="slider-mb-curve-transport" class="tf-transport-group hidden">
					<div id="slider-mb-curve-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
					<div id="slider-mb-curve-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
					<div id="slider-mb-curve-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
				</div>
				<div id="kbhint-mb-curve" class="text-sm text-keybind" style="margin-left: auto;">Shift+Scroll</div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-mb-curve-down" class="tf-sm-btn" onclick="widget:mbCurveDown(); event:StopPropagation()">
					<img class="tf-icon-sm" src="/luaui/images/terraform_brush/curve_flat.png" />
				</div>
				<input type="range" id="slider-mb-curve" class="tf-slider" min="1" max="50" step="1" value="10" onchange="widget:mbOnCurveChange(element); event:StopPropagation()" />
				<div id="btn-mb-curve-up" class="tf-sm-btn" onclick="widget:mbCurveUp(); event:StopPropagation()">
					<img class="tf-icon-sm" src="/luaui/images/terraform_brush/curve_sharp.png" />
				</div>
				<input type="text" id="slider-mb-curve-numbox" class="tf-slider-numbox" value="0" />
			</div>

			<div class="divider-horizontal-dark"></div>

			<!-- Metal Undo & Redo -->
			<div id="btn-toggle-mb-undo" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
				<img id="img-toggle-mb-undo" class="tf-icon-sm" src="/luaui/images/terraform_brush/plus.png" />
				<div class="tf-collapsible-title">UNDO &amp; REDO</div>
				<div class="text-sm text-keybind" style="margin-left: auto;">Ctrl+Z</div>
			</div>
			<div id="section-mb-undo" class="hidden">
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-mb-undo" class="tf-history-btn" onclick="widget:tfMbUndo(); event:StopPropagation()">
					<img class="tf-icon-sm" src="/luaui/images/terraform_brush/undo.png" />
				</div>
				<input type="range" id="slider-mb-history" class="tf-slider tf-slider-history" min="0" max="100" step="1" value="100" />
				<div id="btn-mb-redo" class="tf-history-btn" onclick="widget:tfMbRedo(); event:StopPropagation()">
					<img class="tf-icon-sm" src="/luaui/images/terraform_brush/redo.png" />
				</div>
				<input type="text" id="slider-mb-history-numbox" class="tf-slider-numbox" value="0" />
			</div>
			</div><!-- /section-mb-undo -->

			<div class="divider-horizontal-dark"></div>
			<div class="flex flex-row gap-1 mb-1">
				<div id="btn-metal-save" class="tf-action-btn tf-save-btn" style="flex: 1;" onclick="widget:mbSave(); event:StopPropagation()">
					<div class="tf-action-btn-text">SAVE</div>
				</div>
				<div id="btn-metal-load" class="tf-action-btn tf-load-btn" style="flex: 1;" onclick="widget:mbLoad(); event:StopPropagation()">
					<div class="tf-action-btn-text">LOAD</div>
				</div>
				<div id="btn-metal-clean" class="tf-action-btn" style="flex: 1;" onclick="widget:mbClean(); event:StopPropagation()">
					<div id="metal-clean-label" class="tf-action-btn-text">CLEAN</div>
				</div>
			</div>
