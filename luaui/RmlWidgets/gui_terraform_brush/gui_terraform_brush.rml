			<div id="warn-chip-lp-overlays" class="tf-overlay-chip tf-overlay-chip-warn hidden"><div class="tf-overlay-chip-label">Active</div></div>
		</div>
		<div id="section-lp-overlays" class="hidden">
		<div class="flex flex-row items-center gap-1 mb-1">
