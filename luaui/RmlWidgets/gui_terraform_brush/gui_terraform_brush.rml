	<!-- ============ SKYBOX LIBRARY (separate floating window) ============ -->
	<div id="tf-skybox-library-root" class="tf-skybox-library-root hidden widget-shadow rounded-md bg-darkest p-2-5">
		<div class="flex flex-row justify-between items-center mb-2">
			<div class="flex flex-row items-center">
				<div id="tf-skybox-library-handle" class="tf-drag-handle text-2xl font-bold text-light text-outline-darker">Skybox Library</div>
