				</div>
				<input type="range" id="slider-gb-rotation" onchange="widget:gbOnRotChange(element); event:StopPropagation()" class="tf-slider" min="0" max="359" step="1" value="0" />
				<div id="btn-gb-rot-cw" onclick="widget:gbRotCW(); event:StopPropagation()" class="tf-sm-btn">
					<img class="tf-icon-sm" src="/luaui/images/terraform_brush/rot_cw.png" />
				</div>
				<input type="text" id="slider-gb-rotation-numbox" class="tf-slider-numbox" value="0" />
			</div>

			<!-- Fall-off Curve -->
			<div class="flex flex-row items-center mb-1">
				<div class="text-lg text-light">FALL-OFF: <span class="text-xl font-bold tf-slider-val" id="gb-curve-label">1.0</span></div>
				<div id="slider-gb-curve-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
				<div id="slider-gb-curve-transport" class="tf-transport-group hidden">
					<div id="slider-gb-curve-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
					<div id="slider-gb-curve-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
					<div id="slider-gb-curve-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
				</div>
				<div id="kbhint-gb-curve" class="text-sm text-keybind" style="margin-left: auto;">Shift+Scroll</div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-gb-curve-down" onclick="widget:gbCurveDown(); event:StopPropagation()" class="tf-sm-btn">
					<img class="tf-icon-sm" src="/luaui/images/terraform_brush/curve_flat.png" />
				</div>
				<input type="range" id="slider-gb-curve" onchange="widget:gbOnCurveChange(element); event:StopPropagation()" class="tf-slider" min="1" max="50" step="1" value="10" />
				<div id="btn-gb-curve-up" onclick="widget:gbCurveUp(); event:StopPropagation()" class="tf-sm-btn">
					<img class="tf-icon-sm" src="/luaui/images/terraform_brush/curve_sharp.png" />
				</div>
				<input type="text" id="slider-gb-curve-numbox" class="tf-slider-numbox" value="0" />
			</div>


			<div class="divider-horizontal-dark"></div>
			<div class="flex flex-row gap-1 mb-1">
				<div id="btn-grass-save" onclick="widget:gbSave(); event:StopPropagation()" class="tf-action-btn tf-save-btn" style="flex: 1;">
					<div class="tf-action-btn-text">SAVE GRASS MAP</div>
				</div>
			</div>
			<div class="flex flex-row gap-1 mb-1">
				<div id="btn-grass-load" onclick="widget:gbLoad(); event:StopPropagation()" class="tf-action-btn tf-load-btn" style="flex: 1;">
					<div class="tf-action-btn-text">LOAD GRASS MAP</div>
				</div>
				<div id="btn-grass-clean" onclick="widget:gbClean(); event:StopPropagation()" class="tf-action-btn tf-dc-reset-btn" style="flex: 1;">
					<div class="tf-action-btn-text">CLEAN GRASS</div>
				</div>
			</div>
			</div><!-- /section-gb-controls -->

			<div class="divider-horizontal-dark"></div>

			<!-- Undo & Redo -->
			<div id="btn-toggle-gb-undo" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
				<img id="img-toggle-gb-undo" class="tf-icon-sm" src="/luaui/images/terraform_brush/plus.png" />
				<div class="tf-collapsible-title">UNDO &amp; REDO</div>
				<div class="text-sm text-keybind" style="margin-left: auto;">Ctrl+Z / Ctrl+Shift+Z</div>
			</div>
			<div id="section-gb-undo" class="hidden">
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-gb-undo" onclick="widget:gbUndo(); event:StopPropagation()" class="tf-history-btn">
					<img class="tf-icon-sm" src="/luaui/images/terraform_brush/undo.png" />
				</div>
				<input type="range" id="slider-gb-history" onchange="widget:gbOnHistoryChange(element); event:StopPropagation()" class="tf-slider tf-slider-history" min="0" max="0" step="1" value="0" />
				<div id="btn-gb-redo" onclick="widget:gbRedo(); event:StopPropagation()" class="tf-history-btn">
					<img class="tf-icon-sm" src="/luaui/images/terraform_brush/redo.png" />
				</div>
				<input type="text" id="slider-gb-history-numbox" class="tf-slider-numbox" value="0" />
			</div>
			</div><!-- /section-gb-undo -->
