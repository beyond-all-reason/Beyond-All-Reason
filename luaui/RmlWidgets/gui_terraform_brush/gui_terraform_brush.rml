				<div class="tf-collapsible-title">RAMP TYPE</div>
			</div>
			<div id="section-ramp-type">
			<div class="flex flex-row gap-1 mb-1">
				<div id="btn-ramp-straight" class="tf-mode-btn tf-ramp-btn-straight active" onclick="widget:tfRampStraight(); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/shape_ramp_straight.png" />
