		<div class="flex flex-row gap-1 items-center mb-1">
			<div class="text-sm text-keybind" style="width: 20dp;">3</div>
			<div id="btn-env-splatmult-3-down" class="tf-sm-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" /></div>
			<input type="range" id="slider-env-splatmult-3" class="tf-slider" min="0" max="1500" step="1" value="0" />
			<div id="btn-env-splatmult-3-up" class="tf-sm-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" /></div>
			<input type="text" id="slider-env-splatmult-3-numbox" class="tf-slider-numbox" value="0" />
		</div>
		<div class="divider-horizontal-dark"></div>
		<div class="text-sm text-light font-bold mb-1">SPLAT TEX SCALES</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div class="text-sm text-keybind" style="width: 20dp;">0</div>
			<div id="btn-env-splatscale-0-down" class="tf-sm-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" /></div>
			<input type="range" id="slider-env-splatscale-0" class="tf-slider" min="0" max="200" step="1" value="0" />
			<div id="btn-env-splatscale-0-up" class="tf-sm-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" /></div>
			<input type="text" id="slider-env-splatscale-0-numbox" class="tf-slider-numbox" value="0" />
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div class="text-sm text-keybind" style="width: 20dp;">1</div>
			<div id="btn-env-splatscale-1-down" class="tf-sm-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" /></div>
			<input type="range" id="slider-env-splatscale-1" class="tf-slider" min="0" max="200" step="1" value="0" />
			<div id="btn-env-splatscale-1-up" class="tf-sm-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" /></div>
			<input type="text" id="slider-env-splatscale-1-numbox" class="tf-slider-numbox" value="0" />
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div class="text-sm text-keybind" style="width: 20dp;">2</div>
			<div id="btn-env-splatscale-2-down" class="tf-sm-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" /></div>
			<input type="range" id="slider-env-splatscale-2" class="tf-slider" min="0" max="200" step="1" value="0" />
			<div id="btn-env-splatscale-2-up" class="tf-sm-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" /></div>
			<input type="text" id="slider-env-splatscale-2-numbox" class="tf-slider-numbox" value="0" />
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div class="text-sm text-keybind" style="width: 20dp;">3</div>
