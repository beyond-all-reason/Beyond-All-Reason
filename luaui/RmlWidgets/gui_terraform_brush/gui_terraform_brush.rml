					<div class="tf-overlay-chip-label">Active</div>
				</div>
				<img id="btn-gb-smart-toggle" onclick="widget:gbSmartToggle(); event:StopPropagation()" class="tf-icon-sm hidden" src="/luaui/images/terraform_brush/check_off.png" />
