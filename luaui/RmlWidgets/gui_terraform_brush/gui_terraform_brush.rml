					<img class="tf-icon-md" src="/luaui/images/terraform_brush/mb_paint.png" />
					<div class="tf-btn-text">Paint</div>
				</div>
				<div id="btn-gb-fill" onclick="widget:gbSetSubMode('fill'); event:StopPropagation()" class="tf-mode-btn tf-gb-btn-fill">
