				<div class="tf-action-btn-text">SET</div>
			</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div class="text-sm text-keybind" style="width: 70dp;">max height</div>
			<input type="text" id="input-dim-maxheight" class="tf-dim-input" value="" />
			<div id="btn-dim-maxheight-apply" class="tf-action-btn" onclick="widget:envApplyMaxHeight(); event:StopPropagation()">
				<div class="tf-action-btn-text">SET</div>
			</div>
		</div>
	</div>

	<!-- ============ SPLAT TEX PARAMS (separate floating window) ============ -->
	<div id="tf-splattex-root" class="tf-env-float-window hidden widget-shadow rounded-md bg-darkest p-2-5" style="left: 35vw; top: 15vh;">
		<div class="flex flex-row justify-between items-center mb-2">
