	<!-- ============ DIMENSIONS (floating window) ============ -->
	<div id="tf-env-dimensions-root" class="tf-env-float-window hidden widget-shadow rounded-md bg-darkest p-2-5" style="left: 58vw; top: 20vh;">
		<div class="flex flex-row justify-between items-center mb-2">
			<div id="tf-env-dimensions-handle" class="tf-drag-handle text-xl font-bold text-light text-outline-darker" style="flex: 1;">Dimensions</div>
			<div id="btn-env-dimensions-close" class="tf-quit-btn"><img class="tf-icon-sm" src="/luaui/images/terraform_brush/close.png" /></div>
		</div>

		<!-- MAP SIZE (read-only) -->
		<div class="tf-collapsible-title mb-1">MAP SIZE</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div class="text-sm text-keybind" style="width: 70dp;">width (X)</div>
			<div class="text-sm text-light" id="lbl-dim-map-x">--</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div class="text-sm text-keybind" style="width: 70dp;">depth (Z)</div>
			<div class="text-sm text-light" id="lbl-dim-map-z">--</div>
		</div>
		<div class="divider-horizontal-dark"></div>

		<!-- HEIGHT EXTREMES -->
		<div class="flex flex-row items-center mb-1">
			<div class="tf-collapsible-title" style="flex: 1;">HEIGHT EXTREMES</div>
			<div id="btn-dim-refresh-extremes" class="tf-env-reset-btn" onclick="widget:envDimRefresh(); event:StopPropagation()"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/redo.png" /></div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div class="text-sm text-keybind" style="width: 70dp;">init min</div>
			<div class="text-sm text-light" id="lbl-dim-init-min">--</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div class="text-sm text-keybind" style="width: 70dp;">init max</div>
			<div class="text-sm text-light" id="lbl-dim-init-max">--</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div class="text-sm text-keybind" style="width: 70dp;">curr min</div>
			<div class="text-sm text-light font-bold" id="lbl-dim-curr-min">--</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div class="text-sm text-keybind" style="width: 70dp;">curr max</div>
			<div class="text-sm text-light font-bold" id="lbl-dim-curr-max">--</div>
		</div>
		<div class="divider-horizontal-dark"></div>

		<!-- WATER LEVEL -->
		<div class="flex flex-row items-center mb-1">
			<div class="tf-collapsible-title" style="flex: 1;">WATER LEVEL</div>
			<div id="btn-dim-reset-waterlevel" class="tf-env-reset-btn" onclick="widget:envResetWaterLevel(); event:StopPropagation()">RESET</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div class="text-sm text-keybind" style="width: 70dp;">plane level</div>
			<div class="text-sm text-light" id="lbl-dim-water-plane">--</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div class="text-sm text-keybind" style="width: 70dp;">adjust</div>
			<input type="text" id="input-dim-waterlevel" class="tf-dim-input" value="0" />
			<div id="btn-dim-waterlevel-apply" class="tf-action-btn tf-save-btn" onclick="widget:envApplyWaterLevel(); event:StopPropagation()">
				<div class="tf-action-btn-text">SET</div>
			</div>
		</div>
		<div class="text-xs text-keybind mb-1">+ = lower terrain. &#x2212; = raise terrain.</div>
		<div class="divider-horizontal-dark"></div>

		<!-- HEIGHT BOUNDS -->
		<div class="flex flex-row items-center mb-1">
			<div class="tf-collapsible-title" style="flex: 1;">HEIGHT BOUNDS</div>
			<div id="btn-dim-reset-bounds" class="tf-env-reset-btn" onclick="widget:envResetBounds(); event:StopPropagation()">RESET</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div class="text-sm text-keybind" style="width: 70dp;">min height</div>
			<input type="text" id="input-dim-minheight" class="tf-dim-input" value="" />
