				<input id="slider-grass-density" onchange="widget:gbOnDensityChange(element); event:StopPropagation()" type="range" class="tf-slider" min="0" max="100" value="80" style="flex:1;" />
				<div id="btn-grass-density-up" onclick="widget:gbDensityUp(); event:StopPropagation()" class="tf-sm-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" /></div>
				<input type="text" id="slider-grass-density-numbox" class="tf-slider-numbox" value="80" />
			</div>

			<div class="divider-horizontal-dark"></div>

			<!-- Size -->
			<div class="flex flex-row items-center mb-1">
				<div class="text-lg text-light">SIZE: <span class="text-xl font-bold tf-slider-val" id="gb-size-label">100</span></div>
				<div id="slider-gb-size-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
				<div id="slider-gb-size-transport" class="tf-transport-group hidden">
					<div id="slider-gb-size-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
					<div id="slider-gb-size-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
					<div id="slider-gb-size-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
				</div>
				<div id="kbhint-gb-size" class="text-sm text-keybind" style="margin-left: auto;">Ctrl+Scroll</div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-gb-size-down" onclick="widget:gbSizeDown(); event:StopPropagation()" class="tf-sm-btn">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
				</div>
				<input type="range" id="slider-gb-size" onchange="widget:gbOnSizeChange(element); event:StopPropagation()" class="tf-slider" min="8" max="2000" step="1" value="100" />
				<div id="btn-gb-size-up" onclick="widget:gbSizeUp(); event:StopPropagation()" class="tf-sm-btn">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
				</div>
				<input type="text" id="slider-gb-size-numbox" class="tf-slider-numbox" value="0" />
			</div>

			<!-- Length Scale -->
			<div class="flex flex-row items-center mb-1">
				<div class="text-lg text-light">LENGTH: <span class="text-xl font-bold tf-slider-val" id="gb-length-label">1.0</span></div>
				<div id="slider-gb-length-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
				<div id="slider-gb-length-transport" class="tf-transport-group hidden">
					<div id="slider-gb-length-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
					<div id="slider-gb-length-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
					<div id="slider-gb-length-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
				</div>
				<div id="kbhint-gb-length" class="text-sm text-keybind" style="margin-left: auto;">Alt+Ctrl+Scroll</div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-gb-length-down" onclick="widget:gbLengthDown(); event:StopPropagation()" class="tf-sm-btn">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
				</div>
				<input type="range" id="slider-gb-length" onchange="widget:gbOnLengthChange(element); event:StopPropagation()" class="tf-slider" min="2" max="50" step="1" value="10" />
				<div id="btn-gb-length-up" onclick="widget:gbLengthUp(); event:StopPropagation()" class="tf-sm-btn">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
				</div>
				<input type="text" id="slider-gb-length-numbox" class="tf-slider-numbox" value="0" />
			</div>

			<!-- Rotation -->
			<div class="flex flex-row items-center mb-1">
				<div class="text-lg text-light">ROTATION: <span class="text-xl font-bold tf-slider-val" id="gb-rotation-label">0&#176;</span></div>
				<div id="slider-gb-rotation-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
				<div id="slider-gb-rotation-transport" class="tf-transport-group hidden">
					<div id="slider-gb-rotation-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
					<div id="slider-gb-rotation-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
					<div id="slider-gb-rotation-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
				</div>
				<div id="kbhint-gb-rotation" class="text-sm text-keybind" style="margin-left: auto;">Alt+Scroll</div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-gb-rot-ccw" onclick="widget:gbRotCCW(); event:StopPropagation()" class="tf-sm-btn">
