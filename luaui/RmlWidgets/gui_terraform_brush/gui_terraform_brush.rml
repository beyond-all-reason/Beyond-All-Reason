					<img class="tf-icon-md" src="/luaui/images/terraform_brush/fp_scatter.png" />
					<div class="tf-btn-text">Scatter</div>
				</div>
				<div id="btn-fp-point" class="tf-mode-btn tf-fp-btn-point" onclick="widget:fpSetMode('point'); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/fp_point.png" />
					<div class="tf-btn-text">Point</div>
				</div>
				<div id="btn-fp-remove" class="tf-mode-btn tf-fp-btn-remove" onclick="widget:fpSetMode('remove'); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/fp_remove.png" />
					<div class="tf-btn-text">Remove</div>
				</div>
			</div>
			</div><!-- /section-fp-mode -->
			<div class="divider-horizontal-dark"></div>
		</div>

		<!-- Ramp type row (visible only when Ramp mode active) -->
		<div id="tf-ramp-type-row" class="hidden">
			<div id="btn-toggle-ramp-type" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
