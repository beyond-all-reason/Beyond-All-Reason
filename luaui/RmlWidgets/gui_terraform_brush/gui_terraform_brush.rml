			<input type="range" id="slider-env-splatscale-3" class="tf-slider" min="0" max="200" step="1" value="0" />
			<div id="btn-env-splatscale-3-up" class="tf-sm-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" /></div>
