		<!-- Smooth/Level submode row (visible only when Smooth or Level mode active in terraform brush) -->
		<div id="tf-smooth-submodes" class="hidden">
			<div id="btn-toggle-smooth-mode" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
				<img id="img-toggle-smooth-mode" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
				<div class="tf-collapsible-title">MODIFY MODE</div>
			</div>
			<div id="section-smooth-mode">
			<div class="flex flex-row gap-1 mb-1">
				<div id="btn-smooth-sub-smooth" class="tf-mode-btn tf-sm-btn-smooth" onclick="widget:tfSmoothSubMode('smooth'); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/sm_smooth.png" />
					<div class="tf-btn-text">Smooth</div>
				</div>
				<div id="btn-smooth-sub-level" class="tf-mode-btn tf-sm-btn-level" onclick="widget:tfSmoothSubMode('level'); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/sm_level.png" />
					<div class="tf-btn-text">Level</div>
				</div>
			</div>
			</div><!-- /section-smooth-mode -->
			<div class="divider-horizontal-dark"></div>
		</div>

		<!-- Decal placement mode row (visible only when Decals mode active) -->
		<div id="tf-dc-submodes" class="hidden">
			<div id="btn-toggle-dc-mode" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
				<img id="img-toggle-dc-mode" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
				<div class="tf-collapsible-title">PLACEMENT MODE</div>
			</div>
			<div id="section-dc-mode">
			<div class="flex flex-row gap-1 mb-1">
				<div id="btn-dc-library-scatter" class="tf-mode-btn tf-dc-btn-scatter" onclick="widget:dcLibScatter(); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/fp_scatter.png" />
					<div class="tf-btn-text">Scatter</div>
				</div>
				<div id="btn-dc-library-point" class="tf-mode-btn tf-dc-btn-point" onclick="widget:dcLibPoint(); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/fp_point.png" />
					<div class="tf-btn-text">Point</div>
				</div>
				<div id="btn-dc-library-remove" class="tf-mode-btn tf-dc-btn-remove" onclick="widget:dcLibRemove(); event:StopPropagation()">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/fp_remove.png" />
					<div class="tf-btn-text">Remove</div>
				</div>
			</div>
			</div><!-- /section-dc-mode -->

			<!-- DC: DISTRIBUTION (nested under PLACEMENT MODE) -->
			<div id="btn-toggle-dc-dist" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
				<img id="img-toggle-dc-dist" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
				<div class="tf-collapsible-title">DISTRIBUTION</div>
			</div>
			<div id="section-dc-dist">
			<div class="flex flex-row gap-1 mb-1">
				<div id="btn-dc-dist-random" class="tf-fp-dist-btn active" onclick="widget:dcSetDist('random'); event:StopPropagation()">
					<img class="tf-icon-dist" src="/luaui/images/terraform_brush/fp_scatter.png" />
					<div class="tf-btn-text">Random</div>
				</div>
				<div id="btn-dc-dist-regular" class="tf-fp-dist-btn" onclick="widget:dcSetDist('regular'); event:StopPropagation()">
					<img class="tf-icon-dist" src="/luaui/images/terraform_brush/dist_regular.png" />
					<div class="tf-btn-text">Regular</div>
				</div>
				<div id="btn-dc-dist-clustered" class="tf-fp-dist-btn" onclick="widget:dcSetDist('clustered'); event:StopPropagation()">
					<img class="tf-icon-dist" src="/luaui/images/terraform_brush/dist_clustered.png" />
					<div class="tf-btn-text">Clustered</div>
				</div>
			</div>
			</div><!-- /section-dc-dist -->
			<div class="divider-horizontal-dark"></div>
		</div>

		<!-- Weather sub-mode row (visible only when Weather mode active) -->
		<div id="tf-weather-submodes" class="hidden">
			<div id="btn-toggle-wb-mode" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
				<img id="img-toggle-wb-mode" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
				<div class="tf-collapsible-title">PLACEMENT MODE</div>
			</div>
			<div id="section-wb-mode">
			<div class="flex flex-row gap-1 mb-1">
				<div id="btn-wb-scatter" class="tf-mode-btn tf-wb-btn-scatter">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/fp_scatter.png" />
					<div class="tf-btn-text">Scatter</div>
				</div>
				<div id="btn-wb-point" class="tf-mode-btn tf-wb-btn-point">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/fp_point.png" />
					<div class="tf-btn-text">Point</div>
				</div>
				<div id="btn-wb-remove" class="tf-mode-btn tf-wb-btn-remove">
					<img class="tf-icon-md" src="/luaui/images/terraform_brush/fp_remove.png" />
					<div class="tf-btn-text">Remove</div>
				</div>
			</div>
			</div><!-- /section-wb-mode -->

			<!-- WB: DISTRIBUTION (nested under PLACEMENT MODE) -->
			<div id="btn-toggle-wb-dist" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
				<img id="img-toggle-wb-dist" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
				<div class="tf-collapsible-title">DISTRIBUTION</div>
			</div>
			<div id="section-wb-dist">
			<div class="flex flex-row gap-1 mb-1">
				<div id="btn-wb-dist-random" class="tf-fp-dist-btn active">
					<img class="tf-icon-dist" src="/luaui/images/terraform_brush/fp_scatter.png" />
					<div class="tf-btn-text">Random</div>
				</div>
				<div id="btn-wb-dist-regular" class="tf-fp-dist-btn">
					<img class="tf-icon-dist" src="/luaui/images/terraform_brush/dist_regular.png" />
					<div class="tf-btn-text">Regular</div>
				</div>
				<div id="btn-wb-dist-clustered" class="tf-fp-dist-btn">
					<img class="tf-icon-dist" src="/luaui/images/terraform_brush/dist_clustered.png" />
					<div class="tf-btn-text">Clustered</div>
				</div>
			</div>
			</div><!-- /section-wb-dist -->
			<div class="divider-horizontal-dark"></div>
		</div>

		<!-- ============ TERRAFORM-ONLY CONTROLS ============ -->
		<div id="tf-terraform-controls">

		<div class="divider-horizontal-dark"></div>

		<!-- Display-options collapse header (was OVERLAYS) -->
		<div id="btn-toggle-overlays" class="flex flex-row items-center gap-1 mb-1" style="cursor: pointer;">
			<img id="img-toggle-overlays" class="tf-icon-sm" src="/luaui/images/terraform_brush/plus.png" />
			<div class="text-base text-keybind" style="margin-right: 2dp;">DISPLAY</div>
			<div id="warn-chip-overlays" class="tf-overlay-chip tf-overlay-chip-warn hidden">
				<div class="tf-overlay-chip-label">Active</div>
			</div>
		</div>
		<div id="section-overlays" class="hidden">
		<div class="flex flex-row items-center gap-1 mb-1">
			<div id="btn-grid-overlay" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label">Grid</div>
			</div>
			<div id="btn-height-colormap" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label">Height Map</div>
			</div>
		</div>
		</div><!-- /section-overlays -->

		<div class="divider-horizontal-dark"></div>

		<!-- Instruments toggle header + section -->
		<div id="btn-toggle-instruments" class="flex flex-row items-center gap-1 mb-1" style="cursor: pointer;">
			<img id="img-toggle-instruments" class="tf-icon-sm" src="/luaui/images/terraform_brush/plus.png" />
			<div class="text-base text-keybind" style="margin-right: 2dp;">INSTRUMENTS</div>
			<div id="warn-chip-instruments" class="tf-overlay-chip tf-overlay-chip-warn hidden">
				<div class="tf-overlay-chip-label">Active</div>
			</div>
			<div id="instruments-notify-dot" class="tf-notify-dot hidden"></div>
		</div>
		<div id="section-instruments" class="hidden">
		<div class="flex flex-row items-center gap-1 mb-1">
			<div id="btn-grid-snap" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label" style="text-align: center;">Snap</div>
			</div>
			<div id="btn-angle-snap" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label" style="text-align: center;">Protractor</div>
			</div>
			<div id="btn-measure" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label" style="text-align: center;">Measure</div>
			</div>
			<div id="btn-symmetry" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label" style="text-align: center;">Symmetry</div>
			</div>
		</div>
		<div id="grid-snap-size-row" class="tf-instrument-sub hidden mb-1">
			<div class="flex flex-row justify-between items-center mb-1">
				<div class="text-lg text-light">SNAP SIZE: <span class="text-xl font-bold" id="grid-snap-size-label">48</span></div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-snap-size-down" class="tf-sm-btn">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
				</div>
				<input type="range" id="slider-grid-snap-size" class="tf-slider" min="16" max="128" step="16" value="48" />
				<div id="btn-snap-size-up" class="tf-sm-btn">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
				</div>
				<input type="text" id="slider-grid-snap-size-numbox" class="tf-slider-numbox" readonly value="48" />
			</div>
		</div>
		<div id="angle-snap-step-row" class="tf-instrument-sub hidden mb-1">
			<!-- Row 1: step preset selector -->
			<div class="flex flex-row justify-between items-center mb-1">
				<div class="text-lg text-light">ANGLE STEP: <span class="text-xl font-bold" id="angle-snap-step-label">15</span>&#176;</div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-angle-step-down" class="tf-sm-btn">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
				</div>
				<input type="range" id="slider-angle-snap-step" class="tf-slider" min="0" max="5" step="1" value="1" />
				<div id="btn-angle-step-up" class="tf-sm-btn">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
				</div>
				<input type="text" id="slider-angle-snap-step-numbox" class="tf-slider-numbox" readonly value="15" />
			</div>
			<!-- Row 2: LOCKED AXIS title with Auto-Snap pill -->
			<div class="flex flex-row items-center mb-1">
				<div class="text-lg text-light">LOCKED AXIS: <span class="text-xl font-bold" id="angle-manual-spoke-label">0</span>&#176;</div>
				<div id="btn-angle-autosnap" class="tf-inline-chip" style="margin-left: 4dp;">Auto-Snap</div>
				<div id="kbhint-protractor" class="text-sm text-keybind" style="margin-left: auto;">Alt+Scroll</div>
			</div>
			<!-- Row 3: manual spoke slider (hidden when autosnap ON) -->
			<div id="angle-manual-spoke-row" class="hidden mb-1">
				<div class="flex flex-row gap-1 items-center mb-1">
					<div id="btn-manual-spoke-down" class="tf-sm-btn">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
					</div>
					<input type="range" id="slider-manual-spoke" class="tf-slider" min="0" max="23" step="1" value="0" />
					<div id="btn-manual-spoke-up" class="tf-sm-btn">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
					</div>
				</div>
			</div>
		</div>
		<div id="measure-toolbar-row" class="tf-instrument-sub hidden mb-1">
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-measure-ruler" class="tf-overlay-chip" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Ruler Mode</div>
				</div>
				<div id="btn-measure-sticky" class="tf-overlay-chip" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Sticky</div>
				</div>
				<div id="btn-measure-show-length" class="tf-overlay-chip" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Show Length</div>
				</div>
			</div>
			<!-- Auto Ramp full-width toggle -->
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-measure-ramp-attach" class="tf-overlay-chip active" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Auto Ramp</div>
				</div>
			</div>
			<!-- Paired clear actions -->
			<div class="flex flex-row gap-1 items-center">
				<div id="btn-measure-clear-ramps" class="tf-sm-btn" style="flex: 1;">
					<div class="text-sm" style="text-align: center;">Clear Ramps</div>
				</div>
				<div id="btn-measure-clear" class="tf-sm-btn" style="flex: 1;">
					<div class="text-sm" style="text-align: center;">Clear All</div>
				</div>
			</div>
		</div>
		<div id="symmetry-toolbar-row" class="tf-instrument-sub hidden mb-1">
			<!-- Mode toggles: Radial vs X/Y mirror -->
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-symmetry-radial" class="tf-overlay-chip" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Radial</div>
				</div>
				<div id="btn-symmetry-mirror-x" class="tf-overlay-chip" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Mirror X</div>
				</div>
				<div id="btn-symmetry-mirror-y" class="tf-overlay-chip" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Mirror Y</div>
				</div>
			</div>
			<!-- Flipped modifier (always shown) -->
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-symmetry-flipped" class="tf-overlay-chip" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Flipped</div>
				</div>
			</div>
			<!-- Distort modifier (visible when measure tool also active) -->
			<div id="btn-measure-distort" class="tf-overlay-chip hidden mb-1" style="text-align: center;">
				<div class="tf-overlay-chip-label" style="text-align: center;">Distort</div>
			</div>
			<!-- Radial count (visible only when radial active) -->
			<div id="symmetry-radial-count-row" class="hidden mb-1">
				<div class="flex flex-row justify-between items-center mb-1">
					<div class="text-lg text-light">COPIES: <span class="text-xl font-bold" id="symmetry-radial-count-label">2</span></div>
				</div>
				<div class="flex flex-row gap-1 items-center mb-1">
					<div id="btn-symmetry-count-down" class="tf-sm-btn">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
					</div>
					<input type="range" id="slider-symmetry-radial-count" class="tf-slider" min="2" max="16" step="1" value="2" />
					<div id="btn-symmetry-count-up" class="tf-sm-btn">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
					</div>
				</div>
			</div>
			<!-- Mirror axis rotation (visible only when X or Y mirror active) -->
			<div id="symmetry-mirror-angle-row" class="hidden mb-1">
				<div class="flex flex-row justify-between items-center mb-1">
					<div class="text-lg text-light">AXIS ANGLE: <span class="text-xl font-bold" id="symmetry-mirror-angle-label">0</span>&#176;</div>
				</div>
				<div class="flex flex-row gap-1 items-center mb-1">
					<div id="btn-symmetry-angle-down" class="tf-sm-btn">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
					</div>
					<input type="range" id="slider-symmetry-mirror-angle" class="tf-slider" min="0" max="360" step="5" value="0" />
					<div id="btn-symmetry-angle-up" class="tf-sm-btn">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
					</div>
				</div>
			</div>
			<!-- Origin placement -->
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-symmetry-place-origin" class="tf-sm-btn" style="flex: 1;">
					<div class="text-sm" style="text-align: center;">Set Origin</div>
				</div>
				<div id="btn-symmetry-center-origin" class="tf-sm-btn" style="flex: 1;">
					<div class="text-sm" style="text-align: center;">Center</div>
				</div>
			</div>
			<!-- Clear all symmetry settings -->
			<div class="flex flex-row gap-1 items-center">
				<div id="btn-symmetry-clear" class="tf-sm-btn" style="flex: 1;">
					<div class="text-sm" style="text-align: center;">Reset</div>
				</div>
			</div>
		</div>
		</div><!-- /section-instruments -->

		<div class="divider-horizontal-dark"></div>

		<!-- Controls toggle header + section -->
		<div id="btn-toggle-sliders" class="flex flex-row items-center gap-1 mb-1" style="cursor: pointer;">
			<img id="img-toggle-sliders" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
			<div class="text-base text-keybind">CONTROLS</div>
		</div>
		<div id="section-sliders">
		<div class="flex flex-row items-center gap-1 mb-1">
			<div id="param-chip-rotation" class="tf-overlay-chip active">
				<div class="tf-overlay-chip-label">Rotation</div>
			</div>
			<div id="param-chip-intensity" class="tf-overlay-chip active">
				<div class="tf-overlay-chip-label">Intensity</div>
			</div>
			<div id="param-chip-size" class="tf-overlay-chip active">
				<div class="tf-overlay-chip-label">Size</div>
			</div>
			<div id="param-chip-length" class="tf-overlay-chip active">
				<div class="tf-overlay-chip-label">Length</div>
			</div>
			<div id="param-chip-falloff" class="tf-overlay-chip active">
				<div class="tf-overlay-chip-label">Fall-off</div>
			</div>
		</div>

		<div id="param-rotation-row">
		<div class="flex flex-row items-center mb-1">
			<div class="text-lg text-light">ROTATION: <span class="text-xl font-bold tf-slider-val">{{rotationDeg}}&#176;</span></div>
			<div id="slider-rotation-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
			<div id="slider-rotation-transport" class="tf-transport-group hidden">
				<div id="slider-rotation-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
				<div id="slider-rotation-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
				<div id="slider-rotation-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
			</div>
			<div id="kbhint-rotation" class="text-sm text-keybind" style="margin-left: auto;">Alt+Scroll</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div id="btn-rot-ccw" class="tf-sm-btn" onclick="widget:tfRotCCW(); event:StopPropagation()">
				<img class="tf-icon-sm" src="/luaui/images/terraform_brush/rot_ccw.png" />
			</div>
			<input type="range" id="slider-rotation" class="tf-slider" min="0" max="359" step="1" value="0" />
			<div id="btn-rot-cw" class="tf-sm-btn" onclick="widget:tfRotCW(); event:StopPropagation()">
				<img class="tf-icon-sm" src="/luaui/images/terraform_brush/rot_cw.png" />
			</div>
			<input type="text" id="slider-rotation-numbox" class="tf-slider-numbox" value="0" />
		</div>
		</div><!-- /param-rotation-row -->

		<div id="param-intensity-row">
		<div class="flex flex-row items-center mb-1">
			<div class="text-lg text-light">INTENSITY: <span class="text-xl font-bold tf-slider-val">{{intensity}}</span><span id="stamp-badge" class="tf-stamp-badge hidden">STAMP</span></div>
			<div id="btn-velocity-intensity" class="tf-inline-chip" style="margin-left: 4dp;">~Velocity</div>
			<div id="btn-pen-intensity" class="tf-inline-chip hidden" style="margin-left: 4dp;"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/mb_paint.png" style="margin-right: 2dp;" />Pen</div>
			<div id="pen-intensity-label" class="text-sm text-keybind hidden" style="margin-left: 2dp;">0%</div>
			<div id="slider-intensity-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
			<div id="slider-intensity-transport" class="tf-transport-group hidden">
				<div id="slider-intensity-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
				<div id="slider-intensity-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
				<div id="slider-intensity-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
			</div>
			<div id="kbhint-intensity" class="text-sm text-keybind" style="margin-left: auto;">Space+Scroll</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div id="btn-intensity-down" class="tf-sm-btn" onclick="widget:tfIntensityDown(); event:StopPropagation()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
			</div>
			<input type="range" id="slider-intensity" class="tf-slider" min="0" max="1000" step="1" value="333" />
			<div id="btn-intensity-up" class="tf-sm-btn" onclick="widget:tfIntensityUp(); event:StopPropagation()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
			</div>
			<input type="text" id="slider-intensity-numbox" class="tf-slider-numbox" value="0" />
		</div>
		</div><!-- /param-intensity-row -->

		<div id="restore-strength-row" class="hidden">
			<div class="flex flex-row items-center mb-1">
				<div class="text-lg text-light">RESTORE: <span class="text-xl font-bold tf-slider-val" id="restore-strength-label">100%</span></div>
				<div id="slider-restore-strength-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
				<div id="slider-restore-strength-transport" class="tf-transport-group hidden">
					<div id="slider-restore-strength-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
					<div id="slider-restore-strength-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
					<div id="slider-restore-strength-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
				</div>
				<div class="text-sm text-keybind" style="margin-left: auto;">partial blend</div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-restore-strength-down" class="tf-sm-btn" onclick="widget:tfRestoreStrDown(); event:StopPropagation()">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
				</div>
				<input type="range" id="slider-restore-strength" class="tf-slider" min="0" max="100" step="1" value="100" />
				<div id="btn-restore-strength-up" class="tf-sm-btn" onclick="widget:tfRestoreStrUp(); event:StopPropagation()">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
				</div>
				<input type="text" id="slider-restore-strength-numbox" class="tf-slider-numbox" value="0" />
			</div>
		</div>

		<div id="param-size-row">
		<div class="flex flex-row items-center mb-1">
			<div class="text-lg text-light">SIZE: <span class="text-xl font-bold tf-slider-val">{{radius}}</span></div>
			<div id="btn-pen-size" class="tf-inline-chip hidden" style="margin-left: 4dp;"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/mb_paint.png" style="margin-right: 2dp;" />Pen</div>
			<div id="pen-size-label" class="text-sm text-keybind hidden" style="margin-left: 2dp;">0%</div>
			<div id="slider-size-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
			<div id="slider-size-transport" class="tf-transport-group hidden">
				<div id="slider-size-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
				<div id="slider-size-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
				<div id="slider-size-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
			</div>
			<div id="kbhint-size" class="text-sm text-keybind" style="margin-left: auto;">Ctrl+Scroll</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div id="btn-size-down" class="tf-sm-btn" onclick="widget:tfSizeDown(); event:StopPropagation()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
			</div>
			<input type="range" id="slider-size" class="tf-slider" min="8" max="2000" step="1" value="100" />
			<div id="btn-size-up" class="tf-sm-btn" onclick="widget:tfSizeUp(); event:StopPropagation()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
			</div>
			<input type="text" id="slider-size-numbox" class="tf-slider-numbox" value="0" />
		</div>
		</div><!-- /param-size-row -->

		<div id="ring-width-row" class="hidden">
			<div class="flex flex-row items-center mt-1 mb-1">
				<div class="text-lg text-light">RING WIDTH: <span class="text-xl font-bold tf-slider-val" id="ring-width-label">40%</span></div>
				<div id="slider-ring-width-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
				<div id="slider-ring-width-transport" class="tf-transport-group hidden">
					<div id="slider-ring-width-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
					<div id="slider-ring-width-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
					<div id="slider-ring-width-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
				</div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-ring-width-down" class="tf-sm-btn" onclick="widget:tfRingWidthDown(); event:StopPropagation()">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
				</div>
				<input type="range" id="slider-ring-width" class="tf-slider" min="5" max="95" step="5" value="40" />
				<div id="btn-ring-width-up" class="tf-sm-btn" onclick="widget:tfRingWidthUp(); event:StopPropagation()">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
				</div>
				<input type="text" id="slider-ring-width-numbox" class="tf-slider-numbox" value="0" />
			</div>
		</div>

		<div id="param-length-row">
		<div class="flex flex-row items-center mt-1 mb-1">
			<div class="text-lg text-light">LENGTH: <span class="text-xl font-bold tf-slider-val">{{lengthScale}}</span></div>
			<div id="slider-length-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
			<div id="slider-length-transport" class="tf-transport-group hidden">
				<div id="slider-length-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
				<div id="slider-length-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
				<div id="slider-length-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
			</div>
			<div id="kbhint-length" class="text-sm text-keybind" style="margin-left: auto;">Ctrl+Alt+Scroll</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div id="btn-length-down" class="tf-sm-btn" onclick="widget:tfLengthDown(); event:StopPropagation()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
			</div>
			<input type="range" id="slider-length" class="tf-slider" min="2" max="50" step="1" value="10" />
			<div id="btn-length-up" class="tf-sm-btn" onclick="widget:tfLengthUp(); event:StopPropagation()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
			</div>
			<input type="text" id="slider-length-numbox" class="tf-slider-numbox" value="0" />
		</div>
		</div><!-- /param-length-row -->

		<div id="param-falloff-row">
		<div class="flex flex-row items-center mb-1">
			<div class="text-lg text-light">FALL-OFF: <span class="text-xl font-bold tf-slider-val">{{curve}}</span></div>
			<div id="btn-curve-overlay" class="tf-inline-chip" style="margin-left: 4dp;">SHOW</div>
			<div id="slider-curve-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
			<div id="slider-curve-transport" class="tf-transport-group hidden">
				<div id="slider-curve-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
				<div id="slider-curve-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
				<div id="slider-curve-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
			</div>
			<div id="kbhint-curve" class="text-sm text-keybind" style="margin-left: auto;">Shift+Scroll</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div id="btn-curve-down" class="tf-sm-btn" onclick="widget:tfCurveDown(); event:StopPropagation()">
				<img class="tf-icon-sm" src="/luaui/images/terraform_brush/curve_flat.png" />
			</div>
			<input type="range" id="slider-curve" class="tf-slider" min="1" max="50" step="1" value="10" />
			<div id="btn-curve-up" class="tf-sm-btn" onclick="widget:tfCurveUp(); event:StopPropagation()">
				<img class="tf-icon-sm" src="/luaui/images/terraform_brush/curve_sharp.png" />
			</div>
			<input type="text" id="slider-curve-numbox" class="tf-slider-numbox" value="0" />
		</div>
		</div><!-- /param-falloff-row -->

		</div><!-- /section-sliders -->

		<div class="divider-horizontal-dark"></div>

		<div id="btn-toggle-heightcap" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
			<img id="img-toggle-heightcap" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
			<div class="tf-collapsible-title">HEIGHT CAP</div>
		</div>
		<div id="section-heightcap">
		<div class="flex flex-row gap-1 items-center mb-1">
			<img id="btn-cap-absolute" class="tf-icon-sm" src="/luaui/images/terraform_brush/check_on.png" style="cursor: pointer;" />
			<div class="text-lg text-light">Absolute</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-0-5">
			<div class="text-lg" style="color: #f0a030;">Max: <span class="font-bold">{{heightCapMaxStr}}</span></div>
			<div id="btn-sample-max" class="tf-sample-btn">SAMPLE</div>
			<div id="slider-cap-max-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
			<div id="slider-cap-max-transport" class="tf-transport-group hidden">
				<div id="slider-cap-max-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
				<div id="slider-cap-max-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
				<div id="slider-cap-max-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
			</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div id="btn-cap-max-down" class="tf-sm-btn" onclick="widget:tfCapMaxDown(); event:StopPropagation()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
			</div>
			<input type="range" id="slider-cap-max" class="tf-slider tf-slider-cap-max" min="-500" max="500" step="1" value="0" />
			<div id="btn-cap-max-up" class="tf-sm-btn" onclick="widget:tfCapMaxUp(); event:StopPropagation()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
			</div>
			<input type="text" id="slider-cap-max-numbox" class="tf-slider-numbox" value="0" />
		</div>
		<div class="flex flex-row gap-1 items-center mb-0-5">
			<div class="text-lg" style="color: #30a0f0;">Min: <span class="font-bold">{{heightCapMinStr}}</span></div>
			<div id="btn-sample-min" class="tf-sample-btn">SAMPLE</div>
			<div id="slider-cap-min-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
			<div id="slider-cap-min-transport" class="tf-transport-group hidden">
				<div id="slider-cap-min-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
				<div id="slider-cap-min-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
				<div id="slider-cap-min-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
			</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div id="btn-cap-min-down" class="tf-sm-btn" onclick="widget:tfCapMinDown(); event:StopPropagation()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
			</div>
			<input type="range" id="slider-cap-min" class="tf-slider tf-slider-cap-min" min="-500" max="500" step="1" value="0" />
			<div id="btn-cap-min-up" class="tf-sm-btn" onclick="widget:tfCapMinUp(); event:StopPropagation()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
			</div>
			<input type="text" id="slider-cap-min-numbox" class="tf-slider-numbox" value="0" />
		</div>
		</div><!-- /section-heightcap -->

		<div class="divider-horizontal-dark"></div>

		<div id="btn-toggle-tf-undo" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
			<img id="img-toggle-tf-undo" class="tf-icon-sm" src="/luaui/images/terraform_brush/plus.png" />
			<div class="tf-collapsible-title">UNDO &amp; REDO</div>
			<div class="text-sm text-keybind" style="margin-left: auto;">Ctrl+Z / Ctrl+Shift+Z</div>
		</div>
		<div id="section-tf-undo" class="hidden">
		<div class="flex flex-row gap-1 items-center mb-1">
			<div id="btn-undo" class="tf-history-btn" onclick="widget:tfUndo(); event:StopPropagation()">
				<img class="tf-icon-sm" src="/luaui/images/terraform_brush/undo.png" />
			</div>
			<input type="range" id="slider-history" class="tf-slider tf-slider-history" min="0" max="100" step="1" value="100" />
			<div id="btn-redo" class="tf-history-btn" onclick="widget:tfRedo(); event:StopPropagation()">
				<img class="tf-icon-sm" src="/luaui/images/terraform_brush/redo.png" />
			</div>
			<input type="text" id="slider-history-numbox" class="tf-slider-numbox" value="0" />
		</div>
		</div><!-- /section-tf-undo -->

		<div class="divider-horizontal-dark"></div>

		<div id="btn-toggle-presets" class="flex flex-row items-center mb-1" style="cursor: pointer;">
			<img id="img-toggle-presets" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
			<div class="tf-collapsible-title">PRESETS</div>
		</div>
		<div id="section-presets">
		<div class="flex flex-row gap-1 mb-1">
			<input type="text" id="preset-name-input" class="tf-preset-input" maxlength="24" value="" />
			<div id="btn-preset-save" class="tf-preset-btn tf-preset-save">
				<div class="text-base text-medium font-bold">Save</div>
			</div>
			<div id="btn-preset-toggle" class="tf-preset-btn tf-preset-toggle">
				<div class="text-base text-medium font-bold">Browse</div>
			</div>
		</div>
		<div id="preset-dropdown" class="tf-preset-dropdown hidden"></div>
		<div class="flex flex-row gap-1 mb-1">
			<div id="btn-defaults" class="tf-action-btn tf-defaults-btn tf-action-btn-sm" style="flex: 1;"><div class="tf-action-btn-text">Restore Defaults</div></div>
		</div>
		</div><!-- /section-presets -->

		<div class="divider-horizontal-dark"></div>

		<div class="flex flex-row gap-1 mt-2 mb-1" style="position: relative;">
			<div id="btn-export" class="tf-action-btn tf-save-btn tf-action-btn-sm"><div class="tf-action-btn-text">Save Heightmap</div></div>
			<div id="btn-import" class="tf-action-btn tf-load-btn-disabled tf-action-btn-sm"><div class="tf-action-btn-text" style="opacity: 0.4;">Load Heightmap</div></div>
			<div id="tooltip-load" class="tf-tooltip hidden">Coming soon...</div>
		</div>
		<div id="import-progress-row" class="hidden mb-1">
			<div class="text-sm text-light" style="margin-bottom: 2dp;">Importing...</div>
			<div id="import-progress-track" style="height: 6dp; background-color: #333333; border-radius: 3dp; overflow: hidden;">
				<div id="import-progress-fill" style="height: 6dp; width: 0%; background-color: #4a9eff; border-radius: 3dp;"></div>
			</div>
			<div id="import-progress-label" class="text-sm text-medium" style="margin-top: 1dp;">0%</div>
		</div>

		<div class="divider-horizontal-dark"></div>

		</div><!-- /tf-terraform-controls -->

		<!-- ============ FEATURE-ONLY CONTROLS ============ -->
		<div id="tf-feature-controls" class="hidden">

		<div id="btn-toggle-fp-dist" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
			<img id="img-toggle-fp-dist" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
			<div class="tf-collapsible-title">DISTRIBUTION</div>
		</div>
		<div id="section-fp-dist">
		<div class="flex flex-row gap-1 mb-1">
			<div id="btn-fp-dist-random" class="tf-fp-dist-btn active" onclick="widget:fpSetDist('random'); event:StopPropagation()">
				<img class="tf-icon-dist" src="/luaui/images/terraform_brush/fp_scatter.png" />
				<div class="tf-btn-text">Random</div>
			</div>
			<div id="btn-fp-dist-regular" class="tf-fp-dist-btn" onclick="widget:fpSetDist('regular'); event:StopPropagation()">
				<img class="tf-icon-dist" src="/luaui/images/terraform_brush/dist_regular.png" />
				<div class="tf-btn-text">Regular</div>
			</div>
			<div id="btn-fp-dist-clustered" class="tf-fp-dist-btn" onclick="widget:fpSetDist('clustered'); event:StopPropagation()">
				<img class="tf-icon-dist" src="/luaui/images/terraform_brush/dist_clustered.png" />
				<div class="tf-btn-text">Clustered</div>
			</div>
		</div>
		</div><!-- /section-fp-dist -->

		<div class="divider-horizontal-dark"></div>

		<!-- Feature Placer: DISPLAY -->
		<div id="btn-toggle-fp-overlays" class="flex flex-row items-center gap-1 mb-1" style="cursor: pointer;">
			<img id="img-toggle-fp-overlays" class="tf-icon-sm" src="/luaui/images/terraform_brush/plus.png" />
			<div class="text-base text-keybind" style="margin-right: 2dp;">DISPLAY</div>
			<div id="warn-chip-fp-overlays" class="tf-overlay-chip tf-overlay-chip-warn hidden"><div class="tf-overlay-chip-label">Active</div></div>
		</div>
		<div id="section-fp-overlays" class="hidden">
		<div class="flex flex-row items-center gap-1 mb-1">
			<div id="btn-fp-grid-overlay" class="tf-overlay-chip" onclick="widget:fpToggleGridOverlay(); event:StopPropagation()">
				<div class="tf-overlay-chip-label">Grid</div>
			</div>
			<div id="btn-fp-height-colormap" class="tf-overlay-chip" onclick="widget:fpToggleHeightMap(); event:StopPropagation()">
				<div class="tf-overlay-chip-label">Height Map</div>
			</div>
		</div>
		</div><!-- /section-fp-overlays -->

		<div class="divider-horizontal-dark"></div>

		<!-- Feature Placer: INSTRUMENTS -->
		<div id="btn-toggle-fp-instruments" class="flex flex-row items-center gap-1 mb-1" style="cursor: pointer;">
			<img id="img-toggle-fp-instruments" class="tf-icon-sm" src="/luaui/images/terraform_brush/plus.png" />
			<div class="text-base text-keybind" style="margin-right: 2dp;">INSTRUMENTS</div>
			<div id="warn-chip-fp-instruments" class="tf-overlay-chip tf-overlay-chip-warn hidden"><div class="tf-overlay-chip-label">Active</div></div>
		</div>
		<div id="section-fp-instruments" class="hidden">
		<div class="flex flex-row items-center gap-1 mb-1">
			<div id="btn-fp-grid-snap" class="tf-overlay-chip" onclick="widget:fpToggleGridSnap(); event:StopPropagation()">
				<div class="tf-overlay-chip-label" style="text-align: center;">Grid Snap</div>
			</div>
			<div id="btn-fp-measure" class="tf-overlay-chip" onclick="widget:fpToggleMeasure(); event:StopPropagation()">
				<div class="tf-overlay-chip-label" style="text-align: center;">Measure</div>
			</div>
			<div id="btn-fp-symmetry" class="tf-overlay-chip" onclick="widget:fpToggleSymmetry(); event:StopPropagation()">
				<div class="tf-overlay-chip-label" style="text-align: center;">Symmetry</div>
			</div>
		</div>
		<!-- Symmetry sub-toolbar (visible when symmetry active) -->
		<div id="fp-symmetry-toolbar-row" class="tf-instrument-sub hidden mb-1">
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="fp-btn-symmetry-radial" class="tf-overlay-chip" style="flex: 1; text-align: center;" onclick="widget:fpSymRadial(); event:StopPropagation()">
					<div class="tf-overlay-chip-label" style="text-align: center;">Radial</div>
				</div>
				<div id="fp-btn-symmetry-mirror-x" class="tf-overlay-chip" style="flex: 1; text-align: center;" onclick="widget:fpSymMirrorX(); event:StopPropagation()">
					<div class="tf-overlay-chip-label" style="text-align: center;">Mirror X</div>
				</div>
				<div id="fp-btn-symmetry-mirror-y" class="tf-overlay-chip" style="flex: 1; text-align: center;" onclick="widget:fpSymMirrorY(); event:StopPropagation()">
					<div class="tf-overlay-chip-label" style="text-align: center;">Mirror Y</div>
				</div>
			</div>
			<!-- Radial count -->
			<div id="fp-symmetry-radial-count-row" class="hidden mb-1">
				<div class="flex flex-row justify-between items-center mb-1">
					<div class="text-lg text-light">COPIES: <span class="text-xl font-bold" id="fp-symmetry-radial-count-label">2</span></div>
				</div>
				<div class="flex flex-row gap-1 items-center mb-1">
					<div id="fp-btn-symmetry-count-down" class="tf-sm-btn" onclick="widget:fpSymCountDown(); event:StopPropagation()">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
					</div>
					<input type="range" id="fp-slider-symmetry-radial-count" class="tf-slider" min="2" max="16" step="1" value="2" onchange="widget:fpOnSymCountChange(element); event:StopPropagation()" />
					<div id="fp-btn-symmetry-count-up" class="tf-sm-btn" onclick="widget:fpSymCountUp(); event:StopPropagation()">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
					</div>
				</div>
			</div>
			<!-- Mirror axis angle -->
			<div id="fp-symmetry-mirror-angle-row" class="hidden mb-1">
				<div class="flex flex-row justify-between items-center mb-1">
					<div class="text-lg text-light">AXIS ANGLE: <span class="text-xl font-bold" id="fp-symmetry-mirror-angle-label">0</span>&#176;</div>
				</div>
				<div class="flex flex-row gap-1 items-center mb-1">
					<div id="fp-btn-symmetry-angle-down" class="tf-sm-btn" onclick="widget:fpSymAngleDown(); event:StopPropagation()">
