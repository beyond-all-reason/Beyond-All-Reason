		<div class="divider-horizontal-dark"></div>

		<!-- LP: INSTRUMENTS -->
		<div id="btn-toggle-lp-instruments" class="flex flex-row items-center gap-1 mb-1" style="cursor: pointer;">
			<img id="img-toggle-lp-instruments" class="tf-icon-sm" src="/luaui/images/terraform_brush/plus.png" />
			<div class="text-base text-keybind" style="margin-right: 2dp;">INSTRUMENTS</div>
			<div id="warn-chip-lp-instruments" class="tf-overlay-chip tf-overlay-chip-warn hidden"><div class="tf-overlay-chip-label">Active</div></div>
		</div>
		<div id="section-lp-instruments" class="hidden">
		<div class="flex flex-row items-center gap-1 mb-1">
			<div id="btn-lp-grid-snap" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label" style="text-align: center;">Grid Snap</div>
			</div>
			<div id="btn-lp-angle-snap" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label" style="text-align: center;">Protractor</div>
			</div>
			<div id="btn-lp-measure" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label" style="text-align: center;">Measure</div>
			</div>
			<div id="btn-lp-symmetry" class="tf-overlay-chip">
				<div class="tf-overlay-chip-label" style="text-align: center;">Symmetry</div>
			</div>
		</div>
		<div id="lp-measure-toolbar-row" class="tf-instrument-sub hidden mb-1">
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-lp-measure-show-length" class="tf-overlay-chip" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Show Length</div>
				</div>
				<div id="btn-lp-measure-clear" class="tf-sm-btn" style="flex: 1;">
					<div class="text-sm" style="text-align: center;">Clear All</div>
				</div>
			</div>
		</div>
		<div id="lp-symmetry-toolbar-row" class="tf-instrument-sub hidden mb-1">
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-lp-symmetry-radial" class="tf-overlay-chip" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Radial</div>
				</div>
				<div id="btn-lp-symmetry-mirror-x" class="tf-overlay-chip" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Mirror X</div>
				</div>
				<div id="btn-lp-symmetry-mirror-y" class="tf-overlay-chip" style="flex: 1; text-align: center;">
					<div class="tf-overlay-chip-label" style="text-align: center;">Mirror Y</div>
				</div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-lp-symmetry-place-origin" class="tf-sm-btn" style="flex: 1;">
					<div class="text-sm" style="text-align: center;">Set Origin</div>
				</div>
				<div id="btn-lp-symmetry-center-origin" class="tf-sm-btn" style="flex: 1;">
					<div class="text-sm" style="text-align: center;">Center</div>
				</div>
			</div>
		</div>
		</div><!-- /section-lp-instruments -->

		<div class="divider-horizontal-dark"></div>

		<!-- LP: CONTROLS (sliders only) -->
		<div id="btn-toggle-lp-controls" class="flex flex-row items-center gap-1 mb-1" style="cursor: pointer;">
			<img id="img-toggle-lp-controls" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
			<div class="text-base text-keybind" style="margin-right: 2dp;">CONTROLS</div>
		</div>
		<div id="section-lp-controls">

			<!-- Brightness -->
			<div class="flex flex-row justify-between items-center mb-1">
				<div class="text-lg text-light">BRIGHTNESS: <span class="text-xl font-bold" id="lp-brightness-label">2.0</span></div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-lp-brightness-down" class="tf-sm-btn" onclick="widget:lpBrightnessDown(); event:StopPropagation()">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
				</div>
				<input type="range" id="slider-lp-brightness" class="tf-slider" min="1" max="1000" step="1" value="200" onchange="widget:lpOnBrightnessChange(element); event:StopPropagation()" />
				<div id="btn-lp-brightness-up" class="tf-sm-btn" onclick="widget:lpBrightnessUp(); event:StopPropagation()">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
				</div>
				<input type="text" id="slider-lp-brightness-numbox" class="tf-slider-numbox" value="0" />
			</div>

			<!-- Light Radius -->
			<div class="flex flex-row justify-between items-center mb-1">
				<div class="text-lg text-light">LIGHT RADIUS: <span class="text-xl font-bold" id="lp-light-radius-label">300</span></div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-lp-light-radius-down" class="tf-sm-btn" onclick="widget:lpLightRadiusDown(); event:StopPropagation()">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
				</div>
				<input type="range" id="slider-lp-light-radius" class="tf-slider" min="10" max="5000" step="10" value="300" onchange="widget:lpOnLightRadiusChange(element); event:StopPropagation()" />
				<div id="btn-lp-light-radius-up" class="tf-sm-btn" onclick="widget:lpLightRadiusUp(); event:StopPropagation()">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
				</div>
				<input type="text" id="slider-lp-light-radius-numbox" class="tf-slider-numbox" value="0" />
			</div>

			<!-- Elevation -->
			<div class="flex flex-row justify-between items-center mb-1">
				<div class="text-lg text-light">ELEVATION: <span class="text-xl font-bold" id="lp-elevation-label">20</span></div>
				<div class="text-xs text-keybind">Shift+Scroll</div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
				<div id="btn-lp-elevation-down" class="tf-sm-btn" onclick="widget:lpElevDown(); event:StopPropagation()">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
				</div>
				<input type="range" id="slider-lp-elevation" class="tf-slider" min="0" max="2000" step="5" value="20" onchange="widget:lpOnElevChange(element); event:StopPropagation()" />
				<div id="btn-lp-elevation-up" class="tf-sm-btn" onclick="widget:lpElevUp(); event:StopPropagation()">
					<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
				</div>
				<input type="text" id="slider-lp-elevation-numbox" class="tf-slider-numbox" value="0" />
			</div>

			<div class="divider-horizontal-dark"></div>

			<!-- Cone/Beam Direction (hidden for point lights) -->
			<div id="lp-direction-section" class="hidden">
				<div class="text-lg text-light font-bold mb-1">DIRECTION</div>
				<!-- Hemisphere globe + pitch/yaw inputs -->
				<div class="flex flex-row gap-2 items-center mb-1">
					<div id="lp-orient-globe" class="lp-orient-globe">
						<div class="lp-orient-ring lp-orient-horizon"></div>
						<div class="lp-orient-ring lp-orient-mid"></div>
						<div class="lp-orient-compass lp-orient-N">N</div>
						<div class="lp-orient-compass lp-orient-E">E</div>
						<div class="lp-orient-compass lp-orient-S">S</div>
						<div class="lp-orient-compass lp-orient-W">W</div>
						<div class="lp-orient-center"></div>
						<div id="lp-orient-indicator" class="lp-orient-indicator"></div>
					</div>
					<div class="flex flex-col gap-2">
						<div class="flex flex-row gap-1 items-center">
							<div class="lp-orient-label">Pitch</div>
							<input type="text" id="lp-orient-pitch-input" class="lp-orient-numbox" value="-45" />
							<div class="lp-orient-deg">°</div>
						</div>
						<div class="flex flex-row gap-1 items-center">
							<div class="lp-orient-label">Yaw</div>
							<input type="text" id="lp-orient-yaw-input" class="lp-orient-numbox" value="0" />
							<div class="lp-orient-deg">°</div>
						</div>
					</div>
				</div>
				<div class="lp-orient-hintbar">drag · ●=down, edge=horiz · Alt+Scroll=Yaw · Ctrl+Alt=Pitch</div>
			</div>

			<!-- Cone Theta (visible only for cone) -->
			<div id="lp-theta-section" class="hidden">
				<div class="flex flex-row gap-1 items-center mb-1">
					<div class="text-sm text-keybind" style="width: 60dp;">Spread</div>
					<div id="btn-lp-theta-down" class="tf-sm-btn" onclick="widget:lpThetaDown(); event:StopPropagation()">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
					</div>
					<input type="range" id="slider-lp-theta" class="tf-slider" min="50" max="1500" step="1" value="500" onchange="widget:lpOnThetaChange(element); event:StopPropagation()" />
					<div id="btn-lp-theta-up" class="tf-sm-btn" onclick="widget:lpThetaUp(); event:StopPropagation()">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
					</div>
					<input type="text" id="slider-lp-theta-numbox" class="tf-slider-numbox" value="0" />
				</div>
				<div class="divider-horizontal-dark"></div>
			</div>

			<!-- Beam Length (visible only for beam) -->
			<div id="lp-beam-section" class="hidden">
				<div class="flex flex-row gap-1 items-center mb-1">
					<div class="text-sm text-keybind" style="width: 60dp;">Length</div>
					<div id="btn-lp-beam-length-down" class="tf-sm-btn" onclick="widget:lpBeamLenDown(); event:StopPropagation()">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
					</div>
					<input type="range" id="slider-lp-beam-length" class="tf-slider" min="10" max="5000" step="10" value="300" onchange="widget:lpOnBeamLenChange(element); event:StopPropagation()" />
					<div id="btn-lp-beam-length-up" class="tf-sm-btn" onclick="widget:lpBeamLenUp(); event:StopPropagation()">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
					</div>
					<input type="text" id="slider-lp-beam-length-numbox" class="tf-slider-numbox" value="0" />
				</div>
				<div class="divider-horizontal-dark"></div>
			</div>

			<!-- Scatter Controls (visible in scatter mode) -->
			<div id="lp-scatter-section" class="hidden">
				<div class="text-lg text-light font-bold mb-1">SCATTER</div>
				<div class="flex flex-row justify-between items-center mb-1">
					<div class="text-lg text-light">COUNT: <span class="text-xl font-bold" id="lp-count-label">5</span></div>
				</div>
				<div class="flex flex-row gap-1 items-center mb-1">
					<div id="btn-lp-count-down" class="tf-sm-btn" onclick="widget:lpCountDown(); event:StopPropagation()">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
					</div>
					<input type="range" id="slider-lp-count" class="tf-slider" min="1" max="500" step="1" value="5" onchange="widget:lpOnCountChange(element); event:StopPropagation()" />
					<div id="btn-lp-count-up" class="tf-sm-btn" onclick="widget:lpCountUp(); event:StopPropagation()">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
					</div>
