						<div class="tf-overlay-chip-label">Avoid Slopes</div>
					</div>
					<div id="gb-slope-mode-prefer" class="tf-overlay-chip">
						<div class="tf-overlay-chip-label">Prefer Slopes</div>
					</div>
				</div>
				<div id="gb-smart-slope-max-row" class="flex flex-row items-center mb-1">
					<div class="text-lg text-light">MAX SLOPE: <span class="text-xl font-bold tf-slider-val" id="gb-smart-slope-max-label">45</span>&#176;</div>
					<div id="slider-gb-slope-max-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
					<div id="slider-gb-slope-max-transport" class="tf-transport-group hidden">
						<div id="slider-gb-slope-max-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
						<div id="slider-gb-slope-max-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
						<div id="slider-gb-slope-max-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
					</div>
				</div>
				<div id="gb-smart-slope-max-slider-row" class="flex flex-row gap-1 items-center mb-1">
					<div id="btn-gb-slope-max-down" onclick="widget:gbSmartStep('slopeMax', -5); event:StopPropagation()" class="tf-sm-btn">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
					</div>
					<input type="range" id="slider-gb-slope-max" onchange="widget:gbOnSlopeMaxChange(element); event:StopPropagation()" class="tf-slider" min="5" max="89" step="1" value="45" />
					<div id="btn-gb-slope-max-up" onclick="widget:gbSmartStep('slopeMax', 5); event:StopPropagation()" class="tf-sm-btn">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
					</div>
					<input type="text" id="slider-gb-slope-max-numbox" class="tf-slider-numbox" value="0" />
				</div>

				<div id="gb-smart-slope-min-row" class="hidden flex flex-row items-center mb-1">
					<div class="text-lg text-light">MIN SLOPE: <span class="text-xl font-bold" id="gb-smart-slope-min-label">10</span>&#176;</div>
					<div id="slider-gb-slope-min-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
					<div id="slider-gb-slope-min-transport" class="tf-transport-group hidden">
						<div id="slider-gb-slope-min-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
						<div id="slider-gb-slope-min-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
						<div id="slider-gb-slope-min-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
					</div>
				</div>
				<div id="gb-smart-slope-min-slider-row" class="hidden flex flex-row gap-1 items-center mb-1">
					<div id="btn-gb-slope-min-down" onclick="widget:gbSmartStep('slopeMin', -5); event:StopPropagation()" class="tf-sm-btn">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
					</div>
					<input type="range" id="slider-gb-slope-min" onchange="widget:gbOnSlopeMinChange(element); event:StopPropagation()" class="tf-slider" min="1" max="89" step="1" value="10" />
					<div id="btn-gb-slope-min-up" onclick="widget:gbSmartStep('slopeMin', 5); event:StopPropagation()" class="tf-sm-btn">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
					</div>
					<input type="text" id="slider-gb-slope-min-numbox" class="tf-slider-numbox" value="0" />
				</div>
				</div><!-- /gb-smart-slope-content -->

				<!-- Altitude content (toggled by Altitude chip) -->
				<div id="gb-smart-altitude-content" class="hidden">
				<!-- Altitude Min -->
				<div class="flex flex-row gap-1 items-center mb-1">
					<img id="btn-gb-alt-min-enable" onclick="widget:gbSmartSubToggle('altMinEnable'); event:StopPropagation()" class="tf-icon-sm" src="/luaui/images/terraform_brush/check_off.png" />
					<div class="text-lg text-light">Min Altitude: <span class="text-xl font-bold" id="gb-smart-alt-min-label">0</span></div>
					<div id="btn-gb-alt-min-sample" onclick="widget:gbAltSample('gbAltMin'); event:StopPropagation()" class="tf-sample-btn">SAMPLE</div>
					<div id="slider-gb-alt-min-transport-toggle" class="tf-transport-toggle" style="margin-left: 6dp;">DYNAMIC</div>
					<div id="slider-gb-alt-min-transport" class="tf-transport-group hidden">
						<div id="slider-gb-alt-min-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
						<div id="slider-gb-alt-min-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
						<div id="slider-gb-alt-min-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
					</div>
				</div>
				<div id="gb-smart-alt-min-slider-row" class="hidden flex flex-row gap-1 items-center mb-1">
					<div id="btn-gb-alt-min-down" onclick="widget:gbSmartStep('altMin', -10); event:StopPropagation()" class="tf-sm-btn">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
					</div>
					<input type="range" id="slider-gb-alt-min" onchange="widget:gbOnAltMinChange(element); event:StopPropagation()" class="tf-slider" min="-500" max="500" step="1" value="0" />
					<div id="btn-gb-alt-min-up" onclick="widget:gbSmartStep('altMin', 10); event:StopPropagation()" class="tf-sm-btn">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
					</div>
					<input type="text" id="slider-gb-alt-min-numbox" class="tf-slider-numbox" value="0" />
