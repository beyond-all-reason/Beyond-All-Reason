	<!-- ============ LIGHT LIBRARY (separate floating window) ============ -->
	<div id="tf-light-library-root" class="tf-light-library-root hidden widget-shadow rounded-md bg-darkest p-2-5">
		<div class="flex flex-row justify-between items-center mb-1">
			<div id="tf-light-library-handle" class="tf-drag-handle text-xl font-bold text-light text-outline-darker" style="flex: 1;">Light Library</div>
			<div id="btn-light-library-close" class="tf-quit-btn" onclick="widget:llClose(); event:StopPropagation()"><img class="tf-icon-sm" src="/luaui/images/terraform_brush/close.png" /></div>
		</div>

		<!-- Tab bar -->
		<div class="flex flex-row gap-1 mb-1">
			<div id="btn-ll-tab-builtin" class="tf-lp-compact-btn tf-ll-tab-btn active" style="flex:1;" onclick="widget:llTabBuiltin(); event:StopPropagation()">
				<div class="tf-btn-text">Builtin</div>
			</div>
			<div id="btn-ll-tab-user" class="tf-lp-compact-btn tf-ll-tab-btn" style="flex:1;" onclick="widget:llTabUser(); event:StopPropagation()">
				<div class="tf-btn-text">User Presets</div>
			</div>
		</div>

		<!-- Search bar -->
		<div class="ll-search-wrapper mb-1">
			<input type="text" id="ll-search-input" class="ll-search-input" placeholder="Search presets..." onchange="widget:llOnSearch(); event:StopPropagation()" />
			<div id="btn-ll-search-clear" class="ll-search-clear-btn" onclick="widget:llSearchClear(); event:StopPropagation()"><img class="ll-search-clear-icon" src="/luaui/images/terraform_brush/close.png" /></div>
		</div>

		<!-- Builtin presets list -->
		<div id="ll-builtin-list" class="ll-preset-list">
			<!-- Populated dynamically -->
		</div>

		<!-- User presets list -->
		<div id="ll-user-list" class="ll-preset-list hidden">
			<!-- Populated dynamically -->
		</div>

		<div class="divider-horizontal-dark"></div>

		<!-- Save current as preset -->
		<div class="text-xs text-keybind mb-1 mt-1">Save placed lights as user preset:</div>
		<div class="flex flex-row gap-1 items-center">
			<input id="input-ll-preset-name" type="text" class="ll-preset-input" value="" maxlength="48" />
			<div id="btn-ll-save-preset" class="tf-lp-action-btn tf-save-btn" style="width: 50dp;" onclick="widget:llSavePreset(); event:StopPropagation()">
				<div class="tf-action-btn-text">SAVE</div>
			</div>
		</div>

		<!-- Delete / Refresh -->
		<div class="flex flex-row gap-1 mt-1">
			<div id="btn-ll-delete-preset" class="tf-lp-action-btn" style="flex: 1;" onclick="widget:llDeletePreset(); event:StopPropagation()">
				<div class="tf-action-btn-text">DELETE</div>
			</div>
			<div id="btn-ll-refresh" class="tf-lp-action-btn" style="flex: 1;" onclick="widget:llRefresh(); event:StopPropagation()">
				<div class="tf-action-btn-text">REFRESH</div>
			</div>
		</div>
	</div>

	<!-- ============ NOISE PARAMETERS (separate floating window) ============ -->
	<div id="tf-noise-root" class="tf-noise-root hidden widget-shadow rounded-md bg-darkest p-2-5">
		<div class="flex flex-row justify-between items-center mb-2">
			<div id="tf-noise-handle" class="tf-drag-handle text-2xl font-bold text-light text-outline-darker" style="flex: 1;">Noise Parameters</div>
			<div id="btn-noise-close" class="tf-quit-btn" onclick="widget:noClose()"><img class="tf-icon-sm" src="/luaui/images/terraform_brush/close.png" /></div>
		</div>

		<div id="btn-toggle-noise-type" class="flex flex-row items-center mb-0-5" style="cursor: pointer;">
			<img id="img-toggle-noise-type" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
			<div class="tf-collapsible-title">NOISE TYPE</div>
		</div>
		<div id="section-noise-type">
		<div class="flex flex-row gap-1 mb-1">
			<div id="btn-noise-perlin" class="tf-mode-btn tf-noise-type-btn active" onclick="widget:noSetType('perlin')">
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/noise_perlin.png" />
				<div class="tf-btn-text">Perlin</div>
			</div>
			<div id="btn-noise-voronoi" class="tf-mode-btn tf-noise-type-btn" onclick="widget:noSetType('voronoi')">
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/noise_voronoi.png" />
				<div class="tf-btn-text">Voronoi</div>
			</div>
			<div id="btn-noise-fbm" class="tf-mode-btn tf-noise-type-btn" onclick="widget:noSetType('fbm')">
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/noise_fbm.png" />
				<div class="tf-btn-text">FBM</div>
			</div>
			<div id="btn-noise-billow" class="tf-mode-btn tf-noise-type-btn" onclick="widget:noSetType('billow')">
				<img class="tf-icon-md" src="/luaui/images/terraform_brush/noise_billow.png" />
				<div class="tf-btn-text">Billow</div>
			</div>
		</div>
		</div><!-- /section-noise-type -->

		<div class="divider-horizontal-dark"></div>

		<div class="flex flex-row justify-between items-center mb-1">
			<div class="text-lg text-light">SCALE: <span class="text-xl font-bold" id="noise-scale-label">64</span></div>
			<div class="text-sm text-keybind">cell size</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div id="btn-noise-scale-down" class="tf-sm-btn" onclick="widget:noScaleDown()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
			</div>
			<input type="range" id="slider-noise-scale" class="tf-slider" min="8" max="512" step="8" value="64" onchange="widget:noOnScaleChange(element)" />
			<div id="btn-noise-scale-up" class="tf-sm-btn" onclick="widget:noScaleUp()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
			</div>
			<input type="text" id="slider-noise-scale-numbox" class="tf-slider-numbox" value="0" />
		</div>

		<div class="flex flex-row justify-between items-center mb-1">
			<div class="text-lg text-light">OCTAVES: <span class="text-xl font-bold" id="noise-octaves-label">4</span></div>
			<div class="text-sm text-keybind">detail layers</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div id="btn-noise-octaves-down" class="tf-sm-btn" onclick="widget:noOctavesDown()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
			</div>
			<input type="range" id="slider-noise-octaves" class="tf-slider" min="1" max="8" step="1" value="4" onchange="widget:noOnOctavesChange(element)" />
			<div id="btn-noise-octaves-up" class="tf-sm-btn" onclick="widget:noOctavesUp()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
			</div>
			<input type="text" id="slider-noise-octaves-numbox" class="tf-slider-numbox" value="0" />
		</div>

		<div class="flex flex-row justify-between items-center mb-1">
			<div class="text-lg text-light">PERSISTENCE: <span class="text-xl font-bold" id="noise-persistence-label">0.50</span></div>
			<div class="text-sm text-keybind">amplitude decay</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div id="btn-noise-persist-down" class="tf-sm-btn" onclick="widget:noPersistDown()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
			</div>
			<input type="range" id="slider-noise-persistence" class="tf-slider" min="10" max="90" step="5" value="50" onchange="widget:noOnPersistChange(element)" />
			<div id="btn-noise-persist-up" class="tf-sm-btn" onclick="widget:noPersistUp()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
			</div>
			<input type="text" id="slider-noise-persistence-numbox" class="tf-slider-numbox" value="0" />
		</div>

		<div class="flex flex-row justify-between items-center mb-1">
			<div class="text-lg text-light">LACUNARITY: <span class="text-xl font-bold" id="noise-lacunarity-label">2.0</span></div>
			<div class="text-sm text-keybind">frequency growth</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div id="btn-noise-lacun-down" class="tf-sm-btn" onclick="widget:noLacunDown()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
			</div>
			<input type="range" id="slider-noise-lacunarity" class="tf-slider" min="10" max="40" step="1" value="20" onchange="widget:noOnLacunChange(element)" />
			<div id="btn-noise-lacun-up" class="tf-sm-btn" onclick="widget:noLacunUp()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
			</div>
			<input type="text" id="slider-noise-lacunarity-numbox" class="tf-slider-numbox" value="0" />
		</div>

		<div class="flex flex-row items-center mb-1">
			<div class="text-lg text-light">SEED: <span class="text-xl font-bold" id="noise-seed-label">0</span></div>
			<div id="btn-noise-reseed" class="tf-inline-chip" style="margin-left: 4dp; cursor: pointer;" onclick="widget:noReseed()">
				<img class="tf-icon-xs" src="/luaui/images/terraform_brush/rot_cw.png" style="margin-right: 2dp;" />
				RANDOM
			</div>
		</div>
		<div class="flex flex-row gap-1 items-center mb-1">
			<div id="btn-noise-seed-down" class="tf-sm-btn" onclick="widget:noSeedDown()"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" /></div>
			<input type="range" id="slider-noise-seed" class="tf-slider" min="0" max="9999" step="1" value="0" onchange="widget:noOnSeedChange(element)" />
			<div id="btn-noise-seed-up" class="tf-sm-btn" onclick="widget:noSeedUp()"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" /></div>
			<input type="text" id="slider-noise-seed-numbox" class="tf-slider-numbox" value="0" />
		</div>
	</div>

	<!-- ============ SETTINGS WINDOW (floating, toggled by gear button) ============ -->
	<div id="tf-settings-root" class="tf-settings-window widget-shadow rounded-md bg-darkest p-2-5" style="left: 20vw; top: 10vh;" data-if="settingsOpen">
		<div class="flex flex-row justify-between items-center mb-2">
			<div id="tf-settings-handle" class="tf-drag-handle text-xl font-bold text-light text-outline-darker" style="flex: 1;">Settings</div>
			<div id="btn-settings-close" class="tf-quit-btn" onclick="widget:guideCloseSettings(); event:StopPropagation()"><img class="tf-icon-sm" src="/luaui/images/terraform_brush/close.png" /></div>
		</div>

		<!-- Tab bar -->
		<div class="flex flex-row gap-1 mb-2">
			<div id="btn-settings-tab-keybinds" class="tf-settings-tab active" onclick="widget:guideTab('keybinds'); event:StopPropagation()">Keybinds</div>
			<div id="btn-settings-tab-dj" class="tf-settings-tab" onclick="widget:guideTab('dj'); event:StopPropagation()">DJ Mode</div>
			<div id="btn-settings-tab-stroke" class="tf-settings-tab" onclick="widget:guideTab('stroke'); event:StopPropagation()">Stroke</div>
			<div id="btn-settings-tab-general" class="tf-settings-tab" onclick="widget:guideTab('general'); event:StopPropagation()">General</div>
		</div>

		<!-- Keybinds tab content -->
		<div id="settings-tab-keybinds" class="tf-settings-tab-content" data-if="settingsTab == 'keybinds'">
			<div class="text-base text-keybind mb-1">Click a binding to reassign. Press the new key, or Escape to cancel.</div>
			<div id="keybind-list" class="tf-keybind-list">
				<!-- Populated dynamically by Lua -->
			</div>
			<div class="flex flex-row gap-1 mt-2">
				<div id="btn-kb-save" class="tf-action-btn tf-save-btn" style="flex: 1;" onclick="widget:guideKbSave(); event:StopPropagation()">
					<div class="tf-action-btn-text">SAVE</div>
				</div>
				<div id="btn-kb-apply" class="tf-action-btn" style="flex: 1;" onclick="widget:guideKbApply(); event:StopPropagation()">
					<div class="tf-action-btn-text">APPLY</div>
				</div>
				<div id="btn-kb-defaults" class="tf-action-btn" style="flex: 1;" onclick="widget:guideKbDefaults(); event:StopPropagation()">
					<div class="tf-action-btn-text">DEFAULTS</div>
				</div>
				<div id="btn-kb-cancel" class="tf-action-btn" style="flex: 1;" onclick="widget:guideKbCancel(); event:StopPropagation()">
					<div class="tf-action-btn-text">CANCEL</div>
				</div>
			</div>
		</div>

		<!-- DJ Mode tab content -->
		<div id="settings-tab-dj" class="tf-settings-tab-content" data-if="settingsTab == 'dj'">
			<div class="text-sm text-keybind mb-2">Special immersive mode with sensory feedback for your sculpting pleasure or live match DJ-ing! All effects are synced between players in the game.</div>

			<div id="btn-dj-activate" class="tf-dj-activate-row" onclick="widget:guideToggleDjActivate(); event:StopPropagation()">
				<div>
					<div class="tf-dj-activate-name">DJ Mode</div>
					<div class="tf-dj-activate-desc">Enable all DJ Mode effects below</div>
				</div>
				<div id="pill-dj-activate" class="tf-dj-toggle-pill">OFF</div>
			</div>

			<div id="dj-sub-settings" class="tf-dj-sub-settings">
			<div class="text-base text-light font-bold mb-1">VISUAL</div>
			<div id="btn-dust-effects" class="tf-dj-toggle-row" onclick="widget:guideToggleDust(); event:StopPropagation()">
				<div>
					<div class="tf-dj-toggle-name">Dust Visual Effects</div>
					<div class="tf-dj-toggle-desc">Particle puffs and clouds while sculpting</div>
				</div>
				<div id="pill-dust-effects" class="tf-dj-toggle-pill">OFF</div>
			</div>

			<div class="divider-horizontal-dark mb-1" style="margin-top: 6dp;"></div>
			<div class="text-base text-light font-bold mb-1">SOUND</div>
			<div id="btn-seismic-effects" class="tf-dj-toggle-row" onclick="widget:guideToggleSeismic(); event:StopPropagation()">
				<div>
					<div class="tf-dj-toggle-name">Seismic Sound Effects</div>
					<div class="tf-dj-toggle-desc">Ground impact audio while sculpting</div>
				</div>
				<div id="pill-seismic-effects" class="tf-dj-toggle-pill">OFF</div>
			</div>
			</div><!-- end dj-sub-settings -->
		</div>

		<!-- Stroke tab content -->
		<div id="settings-tab-stroke" class="tf-settings-tab-content" data-if="settingsTab == 'stroke'">
			<!-- Pen Pressure -->
			<div id="btn-pen-pressure-toggle" class="tf-dj-activate-row" onclick="widget:guideTogglePenPressure(); event:StopPropagation()">
				<div>
					<div class="tf-dj-activate-name"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/mb_paint.png" style="margin-right: 4dp;" />Pen Pressure</div>
					<div class="tf-dj-activate-desc">Tablet pressure modulates brush intensity</div>
				</div>
				<div id="pill-pen-pressure" class="tf-dj-toggle-pill">OFF</div>
			</div>
			<div id="pen-pressure-sub" class="tf-dj-sub-settings">
				<div class="flex flex-row items-center gap-2 mb-1">
					<img id="btn-pen-mod-intensity" class="tf-icon-sm" src="/luaui/images/terraform_brush/check_on.png" style="cursor: pointer;" onclick="widget:guideTogglePenModInt(); event:StopPropagation()" />
					<div class="text-lg text-light">Modulate intensity</div>
				</div>
				<div class="flex flex-row items-center gap-2 mb-1">
					<img id="btn-pen-mod-size" class="tf-icon-sm" src="/luaui/images/terraform_brush/check_off.png" style="cursor: pointer;" onclick="widget:guideTogglePenModSize(); event:StopPropagation()" />
					<div class="text-lg text-light">Modulate size</div>
				</div>
				<div class="divider-horizontal-dark" style="margin-top: 4dp; margin-bottom: 4dp;"></div>
				<div class="flex flex-row gap-1 items-center mb-1">
					<div class="text-lg text-light" style="min-width: 100dp;">Sensitivity: <span class="text-xl font-bold tf-slider-val" id="pen-sensitivity-label">100</span>%</div>
					<input type="range" id="slider-pen-sensitivity" class="tf-slider" min="10" max="300" step="1" value="100" onchange="widget:guidePenSensitivityChange(element); event:StopPropagation()" />
				</div>
				<div class="flex flex-row gap-1 items-center mb-1">
					<div class="text-lg text-light" style="min-width: 100dp;">Curve:</div>
					<div id="btn-curve-linear" class="tf-inline-chip" style="margin-left: 2dp;" onclick="widget:guideSetCurve(1); event:StopPropagation()">Linear</div>
					<div id="btn-curve-quad" class="tf-inline-chip active" style="margin-left: 2dp;" onclick="widget:guideSetCurve(2); event:StopPropagation()">Quad</div>
					<div id="btn-curve-cubic" class="tf-inline-chip" style="margin-left: 2dp;" onclick="widget:guideSetCurve(3); event:StopPropagation()">Cubic</div>
					<div id="btn-curve-scurve" class="tf-inline-chip" style="margin-left: 2dp;" onclick="widget:guideSetCurve(4); event:StopPropagation()">S</div>
					<div id="btn-curve-log" class="tf-inline-chip" style="margin-left: 2dp;" onclick="widget:guideSetCurve(5); event:StopPropagation()">Log</div>
				</div>
			</div>
			<div class="divider-horizontal-dark" style="margin-top: 6dp; margin-bottom: 6dp;"></div>
			<!-- Wiggle -->
			<div id="btn-wiggle-toggle" class="tf-dj-activate-row" onclick="widget:guideToggleWiggle(); event:StopPropagation()">
				<div>
					<div class="tf-dj-activate-name">Brush Wiggle</div>
					<div class="tf-dj-activate-desc">Sinusoidal brush offset while painting</div>
				</div>
				<div id="pill-wiggle-toggle" class="tf-dj-toggle-pill">OFF</div>
			</div>
			<div id="wiggle-sub" class="tf-dj-sub-settings">
				<div class="flex flex-row items-center gap-2 mb-1">
					<div class="tf-dj-toggle-name" style="min-width: 70dp;">Amplitude</div>
					<div id="btn-wiggle-amp-1" class="tf-wiggle-chip active" onclick="widget:guideWiggleAmp(1); event:StopPropagation()">A1</div>
					<div id="btn-wiggle-amp-2" class="tf-wiggle-chip" onclick="widget:guideWiggleAmp(2); event:StopPropagation()">A2</div>
					<div id="btn-wiggle-amp-3" class="tf-wiggle-chip" onclick="widget:guideWiggleAmp(3); event:StopPropagation()">A3</div>
					<div id="btn-wiggle-amp-4" class="tf-wiggle-chip" onclick="widget:guideWiggleAmp(4); event:StopPropagation()">A4</div>
				</div>
				<div class="flex flex-row items-center gap-2">
					<div class="tf-dj-toggle-name" style="min-width: 70dp;">Speed</div>
					<div id="btn-wiggle-spd-1" class="tf-wiggle-chip active" onclick="widget:guideWiggleSpd(1); event:StopPropagation()">S1</div>
					<div id="btn-wiggle-spd-2" class="tf-wiggle-chip" onclick="widget:guideWiggleSpd(2); event:StopPropagation()">S2</div>
					<div id="btn-wiggle-spd-3" class="tf-wiggle-chip" onclick="widget:guideWiggleSpd(3); event:StopPropagation()">S3</div>
					<div id="btn-wiggle-spd-4" class="tf-wiggle-chip" onclick="widget:guideWiggleSpd(4); event:StopPropagation()">S4</div>
				</div>
			</div>
		</div>

		<!-- General tab content -->
		<div id="settings-tab-general" class="tf-settings-tab-content" data-if="settingsTab == 'general'">
			<div id="btn-ui-disable-tips" class="tf-dj-activate-row" onclick="widget:guideToggleDisableTips(); event:StopPropagation()">
				<div>
					<div class="tf-dj-activate-name">Disable tips/tool recommendations</div>
					<div class="tf-dj-activate-desc">Hides the pulsing blue notification dots on collapsed section headers.</div>
				</div>
				<div id="pill-ui-disable-tips" class="tf-dj-toggle-pill">OFF</div>
			</div>
		</div>
	</div>

	<div id="tf-guide-floating-tip" class="tf-guide-floating-tip hidden"></div>
</body>
</rml>
