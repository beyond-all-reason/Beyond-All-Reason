		<div class="flex flex-row gap-1 mb-1">
			<div id="btn-env-dimensions" class="tf-env-btn" style="flex: 1;">
				<img class="tf-env-btn-icon" src="/luaui/images/terraform_brush/env_dimensions.png" />
