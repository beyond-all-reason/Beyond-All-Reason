						<div id="slider-gb-alt-max-back" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_back.png" /></div>
						<div id="slider-gb-alt-max-play" class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/passthrough_play.png" /></div>
						<div id="slider-gb-alt-max-fwd"  class="tf-transport-btn"><img class="tf-icon-xs" src="/luaui/images/terraform_brush/transport_fwd.png" /></div>
					</div>
				</div>
				<div id="gb-smart-alt-max-slider-row" class="hidden flex flex-row gap-1 items-center mb-1">
					<div id="btn-gb-alt-max-down" onclick="widget:gbSmartStep('altMax', -10); event:StopPropagation()" class="tf-sm-btn">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/minus.png" />
					</div>
					<input type="range" id="slider-gb-alt-max" onchange="widget:gbOnAltMaxChange(element); event:StopPropagation()" class="tf-slider" min="-500" max="500" step="1" value="200" />
					<div id="btn-gb-alt-max-up" onclick="widget:gbSmartStep('altMax', 10); event:StopPropagation()" class="tf-sm-btn">
						<img class="tf-icon-xs" src="/luaui/images/terraform_brush/plus.png" />
					</div>
					<input type="text" id="slider-gb-alt-max-numbox" class="tf-slider-numbox" value="0" />
				</div>
				</div><!-- /gb-smart-altitude-content -->

				<!-- Color content (toggled by Color chip; chip active == texFilterEnabled) -->
				<div id="gb-smart-color-content" class="hidden">
				<div class="flex flex-row gap-1 items-center mb-1">
					<div class="tf-filter-heading">COLOR FILTER</div>
					<div id="btn-gb-pipette" onclick="widget:gbPipette(); event:StopPropagation()" class="tf-gb-pipette-btn" style="margin-left: auto;"><img src="/luaui/images/terraform_brush/gb_pipette.png" style="width: 14dp; height: 14dp; image-color: #cccccc;" /></div>
				</div>
				<div class="mb-1">
					<div id="gb-tex-color-swatch" />
				</div>
				<!-- Exclude color row -->
				<div class="flex flex-row gap-1 items-center mb-1">
					<img id="btn-gb-exclude-toggle" onclick="widget:gbExcludeToggle(); event:StopPropagation()" class="tf-icon-sm" src="/luaui/images/terraform_brush/check_off.png" />
					<div class="tf-filter-heading" style="color: #e07070;">EXCLUDE</div>
					<div id="btn-gb-exclude-pipette" onclick="widget:gbExcludePipette(); event:StopPropagation()" class="tf-gb-pipette-btn" style="margin-left: auto;"><img src="/luaui/images/terraform_brush/gb_pipette.png" style="width: 14dp; height: 14dp; image-color: #e07070;" /></div>
				</div>
				<div class="mb-1">
					<div id="gb-tex-exclude-swatch" />
				</div>
				<div class="flex flex-row items-center mb-1">
					<div class="text-lg text-light">TOLERANCE: <span class="text-xl font-bold" id="gb-color-thresh-label">35</span></div>
				</div>
				<div class="flex flex-row gap-1 items-center mb-1">
					<input type="range" id="slider-gb-color-thresh" onchange="widget:gbOnColorThreshChange(element); event:StopPropagation()" class="tf-slider" min="0" max="150" step="1" value="35" />
					<input type="text" id="slider-gb-color-thresh-numbox" class="tf-slider-numbox" value="35" />
				</div>
				<div class="flex flex-row items-center mb-1">
					<div class="text-lg text-light">EDGE PAD: <span class="text-xl font-bold" id="gb-color-pad-label">0</span></div>
				</div>
				<div class="flex flex-row gap-1 items-center mb-1">
					<input type="range" id="slider-gb-color-pad" onchange="widget:gbOnColorPadChange(element); event:StopPropagation()" class="tf-slider" min="0" max="200" step="8" value="0" />
					<input type="text" id="slider-gb-color-pad-numbox" class="tf-slider-numbox" value="0" />
				</div>
				</div><!-- /gb-smart-color-content -->

			</div><!-- /section-gb-smart -->

			<div class="divider-horizontal-dark"></div>

			<!-- Grass Brush: CONTROLS -->
			<div id="btn-toggle-gb-controls" class="flex flex-row items-center gap-1 mb-1" style="cursor: pointer;">
				<img id="img-toggle-gb-controls" class="tf-icon-sm" src="/luaui/images/terraform_brush/minus.png" />
				<div class="text-base text-keybind">CONTROLS</div>
			</div>
			<div id="section-gb-controls">

			<!-- Density -->
			<div class="flex flex-row justify-between items-center mb-1">
				<div class="text-lg text-light font-bold">Density</div>
				<div id="gb-density-label" class="text-lg text-light">80%</div>
			</div>
			<div class="flex flex-row gap-1 items-center mb-1">
