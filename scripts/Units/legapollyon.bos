// Rear Turret Miniguns
/////////////////////////////////

AimWeapon7(heading, pitch)
{   
    signal SIG_AIM_2;
	set-signal-mask SIG_AIM_2;
    turn RearLeftMinigunTurret to y-axis heading speed <180.000000>;
    turn RearLeftMinigunTurretSleeve to x-axis <0> - pitch speed <90.000000>;
    wait-for-turn RearLeftMinigunTurret around y-axis;
	wait-for-turn RearLeftMinigunTurretSleeve around x-axis;
    start-script RestoreAfterDelay();
    return (1);
}

FireWeapon7()
{
    emit-sfx 1024 + 0 from RearLeftMinigunTurretBarrelFirepoint;
    spin RearLeftMinigunTurretBarrel around z-axis speed <900.000000>;
    stop-spin RearLeftMinigunTurretBarrel around z-axis decelerate <5.000000>;
}

