{
  "$schema": "https://raw.githubusercontent.com/sumneko/vscode-lua/master/setting/schema.json",
  "runtime.version": "Lua 5.1",
  "completion.requireSeparator": "/",
  "runtime.path": [
      "?",
      "?.lua"
  ],
  "runtime.special": {
      "VFS.Include": "require",
      "include": "require",
      "shard_include": "require"
  },
  "workspace": {
    "library": [
      "recoil-lua-library",
      "luarules/",
      "luaui/",
      "spec/",
      "./types/busted/library",
      "./types/luassert/library"
    ],
    "ignoreDir": [
      ".vscode",
      "luaui/Tests",
      "luaui/TestsExamples"
    ]
  },
  "diagnostics": {
    "globals": [
      "VFS",
      "Spring",
      "Game",
      "CMD",
      "gadget",
      "widget",
      "GG",
      "WG",
      "gadgetHandler",
      "widgetHandler"
    ],
    "type": {
      "definition": [
        "luaui/types/"
      ]
    }
  },
  "semantic": {
    "enable": true
  }
}
